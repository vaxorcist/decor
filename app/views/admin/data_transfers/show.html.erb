<%# decor/app/views/admin/data_transfers/show.html.erb %>
<%# version 1.0 %>
<%# Session 24: New view — admin import/export selector page. %>
<%#   Two sections: Export (id="export") and Import (id="import"), stacked vertically. %>
<%#   Each section has a data type selector and an owner dropdown. %>
<%#   Nav anchors (admin_data_transfer_path(anchor: "export/import")) jump directly to each. %>
<%#   Forms use GET (export) and POST/multipart (import) — no JS required. %>
<%#   Owner dropdown is always visible; note text explains when it applies. %>
<%# %>
<%# Supported data types: %>
<%#   computer_models  — exports/imports ComputerModel records (device_type: computer) %>
<%#   appliance_models — exports/imports ComputerModel records (device_type: appliance) %>
<%#   component_types  — exports/imports ComponentType records %>
<%#   owner_collection — exports/imports one owner's computers + components %>
<%#                      (export also supports "all" = all owners, one CSV) %>

<div class="max-w-3xl mx-auto">
  <h1 class="text-2xl font-semibold mb-6">Imports / Exports</h1>

  <%# ── Flash messages ─────────────────────────────────────────────────── %>
  <% if flash[:notice].present? %>
    <div class="mb-6 p-4 rounded border border-green-300 bg-green-50 text-green-800 text-sm">
      <%= flash[:notice] %>
    </div>
  <% end %>
  <% if flash[:alert].present? %>
    <div class="mb-6 p-4 rounded border border-red-300 bg-red-50 text-red-800 text-sm">
      <%= flash[:alert] %>
    </div>
  <% end %>

  <%# ══════════════════════════════════════════════════════════════════════ %>
  <%# EXPORT SECTION                                                         %>
  <%# ══════════════════════════════════════════════════════════════════════ %>
  <div id="export" class="bg-white border border-stone-200 rounded p-6 mb-6">
    <h2 class="text-lg font-semibold mb-1">Export</h2>
    <p class="text-sm text-stone-600 mb-4">
      Download a CSV of the selected data. Use the Owner field only when exporting
      Owner Collection Data.
    </p>

    <%# Export uses GET so the browser triggers a file download on submit. %>
    <%# No CSRF token is sent for GET forms (idempotent). %>
    <%# data: { turbo: false } is required — Turbo intercepts GET form submissions %>
    <%# and silently drops send_data file responses. Bypassing Turbo lets the browser %>
    <%# handle the response natively and trigger the file download dialog. %>
    <%= form_with url: admin_export_data_transfer_path, method: :get,
                  data: { turbo: false }, class: "space-y-4" do |f| %>

      <%# ── Data type selector ─────────────────────────────────────────── %>
      <div>
        <%= label_tag :data_type, "Data Type", class: "block text-sm font-medium text-stone-700 mb-1" %>
        <%= select_tag :data_type,
              options_for_select([
                ["— Select —",             ""],
                ["Computer Models",        "computer_models"],
                ["Appliance Models",       "appliance_models"],
                ["Component Types",        "component_types"],
                ["Owner Collection Data",  "owner_collection"]
              ]),
              required: true,
              class: "block w-full rounded border border-stone-300 bg-white
                      px-3 py-2 text-sm text-stone-700 focus:outline-none
                      focus:ring-1 focus:ring-indigo-500" %>
      </div>

      <%# ── Owner selector (applies to Owner Collection Data only) ────── %>
      <div>
        <%= label_tag :owner_id, "Owner", class: "block text-sm font-medium text-stone-700 mb-1" %>
        <%= select_tag :owner_id,
              options_for_select(
                [["All Owners", "all"]] +
                @owners.map { |o| [o.user_name, o.id] }
              ),
              class: "block w-full rounded border border-stone-300 bg-white
                      px-3 py-2 text-sm text-stone-700 focus:outline-none
                      focus:ring-1 focus:ring-indigo-500" %>
        <p class="mt-1 text-xs text-stone-500">
          Only used for Owner Collection Data. Ignored for all other data types.
        </p>
      </div>

      <div>
        <%= submit_tag "Download CSV",
              class: button_classes(style: :primary) %>
      </div>
    <% end %>
  </div>

  <%# ══════════════════════════════════════════════════════════════════════ %>
  <%# IMPORT SECTION                                                         %>
  <%# ══════════════════════════════════════════════════════════════════════ %>
  <div id="import" class="bg-white border border-stone-200 rounded p-6 mb-6">
    <h2 class="text-lg font-semibold mb-1">Import</h2>
    <p class="text-sm text-stone-600 mb-1">
      Upload a CSV file to create new records. Existing records (matched by name
      or serial number) are silently skipped — safe to re-import the same file.
    </p>
    <ul class="text-sm text-stone-600 mb-4 list-disc list-inside space-y-1">
      <li>Computer / Appliance Models: CSV must have a <code class="font-mono bg-stone-100 px-1 rounded">name</code> column.</li>
      <li>Component Types: CSV must have a <code class="font-mono bg-stone-100 px-1 rounded">name</code> column.</li>
      <li>Owner Collection Data: use the CSV format exported from the owner's Export / Import page.
          Select the target owner below. "All owners" is not available for import.</li>
      <li>The entire file is imported atomically — all rows succeed or none are saved.</li>
    </ul>

    <%# multipart: true is required for file uploads. %>
    <%= form_with url: admin_import_data_transfer_path, method: :post,
                  multipart: true, class: "space-y-4" do |f| %>

      <%# ── Data type selector ─────────────────────────────────────────── %>
      <div>
        <%= f.label :data_type, "Data Type", class: "block text-sm font-medium text-stone-700 mb-1" %>
        <%= f.select :data_type,
              options_for_select([
                ["— Select —",             ""],
                ["Computer Models",        "computer_models"],
                ["Appliance Models",       "appliance_models"],
                ["Component Types",        "component_types"],
                ["Owner Collection Data",  "owner_collection"]
              ]),
              class: "block w-full rounded border border-stone-300 bg-white
                      px-3 py-2 text-sm text-stone-700 focus:outline-none
                      focus:ring-1 focus:ring-indigo-500" %>
      </div>

      <%# ── Owner selector (required for owner_collection imports) ─────── %>
      <div>
        <%= f.label :owner_id, "Owner", class: "block text-sm font-medium text-stone-700 mb-1" %>
        <%= f.select :owner_id,
              options_for_select(
                [["— Select Owner —", ""]] +
                @owners.map { |o| [o.user_name, o.id] }
              ),
              { class: "block w-full rounded border border-stone-300 bg-white
                        px-3 py-2 text-sm text-stone-700 focus:outline-none
                        focus:ring-1 focus:ring-indigo-500" } %>
        <p class="mt-1 text-xs text-stone-500">
          Required when importing Owner Collection Data. Ignored for other data types.
        </p>
      </div>

      <%# ── File upload ────────────────────────────────────────────────── %>
      <div>
        <%= f.label :file, "CSV File", class: "block text-sm font-medium text-stone-700 mb-1" %>
        <%= f.file_field :file,
              accept: ".csv",
              required: true,
              class: "block w-full text-sm text-stone-600
                      file:mr-4 file:py-2 file:px-4 file:rounded
                      file:border-0 file:text-sm file:font-medium
                      file:bg-indigo-50 file:text-indigo-700
                      hover:file:bg-indigo-100" %>
        <p class="mt-1 text-xs text-stone-500">Maximum file size: 10 MB.</p>
      </div>

      <div>
        <%= f.submit "Import CSV", class: button_classes(style: :primary) %>
      </div>
    <% end %>
  </div>

  <%# ── CSV format reference ───────────────────────────────────────────── %>
  <div class="bg-white border border-stone-200 rounded p-6 mb-6">
    <h2 class="text-lg font-semibold mb-3">CSV Formats</h2>

    <%# Computer / Appliance Models %>
    <h3 class="text-sm font-semibold text-stone-700 mb-1">Computer Models / Appliance Models</h3>
    <p class="text-sm text-stone-600 mb-2">
      One record per row. The device type is determined by the selector, not the CSV.
    </p>
    <pre class="text-xs bg-stone-50 border border-stone-200 rounded p-3 mb-4 overflow-x-auto text-stone-700">name
PDP-11/70
VAX-11/780</pre>

    <%# Component Types %>
    <h3 class="text-sm font-semibold text-stone-700 mb-1">Component Types</h3>
    <p class="text-sm text-stone-600 mb-2">One record per row.</p>
    <pre class="text-xs bg-stone-50 border border-stone-200 rounded p-3 mb-4 overflow-x-auto text-stone-700">name
Memory Board
CPU Board</pre>

    <%# Owner Collection Data %>
    <h3 class="text-sm font-semibold text-stone-700 mb-1">Owner Collection Data</h3>
    <p class="text-sm text-stone-600 mb-2">
      Uses the same format as the owner-facing Export / Import page. See that page for the
      full column reference. The "All Owners" export adds an
      <code class="font-mono bg-stone-100 px-1 rounded">owner_user_name</code> column as the
      first column; this format cannot be re-imported directly.
    </p>
  </div>

</div>
