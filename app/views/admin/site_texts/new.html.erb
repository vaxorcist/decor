<%# decor/app/views/admin/site_texts/new.html.erb - version 1.0 %>
<%# v1.0 (Session 18): Admin upload form for a named text page (.md file). %>
<%#   key is carried through a hidden field from the URL query param. %>
<%#   data-turbo: false on the form ensures standard multipart submission — %>
<%#   Turbo's handling of file uploads can be unpredictable. %>
<%#   Shows the currently stored content (truncated) so the admin knows %>
<%#   whether a file already exists before uploading a replacement. %>

<div class="max-w-2xl">
  <h1 class="text-2xl font-semibold mb-6">Upload <%= @title %></h1>

  <%# Show existing content status so the admin knows whether this will replace something. %>
  <% if @site_text.present? %>
    <div class="mb-6 p-3 bg-amber-50 border border-amber-200 rounded text-sm text-amber-800">
      A <strong><%= @title %></strong> is currently stored
      (<%= @site_text.content.length %> characters,
       last updated <%= @site_text.updated_at.strftime("%Y-%m-%d %H:%M") %> UTC).
      Uploading a new file will replace it.
    </div>
  <% else %>
    <div class="mb-6 p-3 bg-blue-50 border border-blue-200 rounded text-sm text-blue-800">
      No <strong><%= @title %></strong> has been uploaded yet.
    </div>
  <% end %>

  <%# data-turbo: false — use standard multipart form submission for file uploads. %>
  <%= form_with url: admin_site_texts_path,
                method: :post,
                multipart: true,
                data: { turbo: false },
                class: "space-y-4" do |f| %>

    <%# Hidden field carries the key through to the create action. %>
    <input type="hidden" name="key" value="<%= @key %>">

    <div>
      <label class="block text-sm font-medium text-stone-700 mb-1">
        Markdown file (.md) <span class="text-red-600">*</span>
      </label>
      <input type="file"
             name="file"
             accept=".md,text/markdown,text/plain"
             required
             class="block w-full text-sm text-stone-700
                    file:mr-4 file:py-2 file:px-4
                    file:rounded file:border-0
                    file:text-sm file:font-medium
                    file:bg-stone-100 file:text-stone-700
                    hover:file:bg-stone-200 cursor-pointer">
      <p class="mt-1 text-xs text-stone-500">
        Upload a .md file. Standard markdown syntax is supported: headings, bold,
        italic, lists, tables, code blocks, and links ([text](/path) or [text](https://...)).
      </p>
    </div>

    <div class="flex gap-3 items-center">
      <button type="submit" class="<%= button_classes(style: :primary) %>">
        Upload <%= @title %>
      </button>
      <%= link_to "Cancel", admin_owners_path, class: button_classes(style: :secondary) %>
    </div>
  <% end %>
</div>
