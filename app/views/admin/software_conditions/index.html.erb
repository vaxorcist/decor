<%# decor/app/views/admin/software_conditions/index.html.erb %>
<%# version 1.0 %>
<%# Lists all software_condition records with their software item counts. %>
<%# Column is "name" (not "condition") — intentional clean convention for this table. %>
<%# Description is truncated at 60 chars; a dash is shown when blank. %>
<div class="max-w-7xl mx-auto">
  <div class="flex justify-between items-center mb-4">
    <h1 class="text-2xl font-semibold">Software Conditions</h1>
    <%= link_to "Add Software Condition", new_admin_software_condition_path, class: button_classes(style: :primary) %>
  </div>

  <% if @software_conditions.any? %>
    <div class="bg-white border border-stone-200 rounded">
      <table class="min-w-full divide-y divide-stone-200">
        <thead class="bg-stone-50">
          <tr>
            <th class="px-4 py-2 text-left text-xs font-medium text-stone-500 uppercase tracking-wider">Condition</th>
            <th class="px-4 py-2 text-left text-xs font-medium text-stone-500 uppercase tracking-wider">Description</th>
            <th class="px-4 py-2 text-left text-xs font-medium text-stone-500 uppercase tracking-wider">Items</th>
            <th class="px-4 py-2"></th>
          </tr>
        </thead>
        <tbody class="bg-white divide-y divide-stone-200 text-sm">
          <% @software_conditions.each do |software_condition| %>
            <tr>
              <td class="px-4 py-3 whitespace-nowrap font-medium text-stone-900"><%= software_condition.name %></td>
              <td class="px-4 py-3 text-stone-600"><%= truncate(software_condition.description, length: 60) || "—" %></td>
              <td class="px-4 py-3 whitespace-nowrap text-stone-600"><%= software_condition.software_items.size %></td>
              <td class="px-4 py-3 whitespace-nowrap text-right space-x-2">
                <%= link_to "Edit", edit_admin_software_condition_path(software_condition), class: "text-stone-700 hover:text-stone-900 text-sm" %>
                <% if software_condition.software_items.empty? %>
                  <%= button_to "Delete", admin_software_condition_path(software_condition), method: :delete, data: { turbo_confirm: "Delete this software condition?" }, class: "text-stone-700 hover:text-stone-900 text-sm" %>
                <% end %>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  <% else %>
    <div class="bg-white border border-stone-200 rounded p-4 text-center text-sm text-stone-500">
      No software conditions yet.
    </div>
  <% end %>
</div>
