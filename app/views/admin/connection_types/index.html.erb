<%# decor/app/views/admin/connection_types/index.html.erb %>
<%# version 1.0 — Session 33 %>
<%# Lists all connection types with name, label, and group count. %>
<%# Delete button hidden when connection_groups exist (restrict_with_error). %>
<div class="max-w-7xl mx-auto">
  <div class="flex justify-between items-center mb-4">
    <h1 class="text-2xl font-semibold">Connection Types</h1>
    <%= link_to "Add Connection Type", new_admin_connection_type_path, class: button_classes(style: :primary) %>
  </div>

  <% if @connection_types.any? %>
    <div class="bg-white border border-stone-200 rounded">
      <table class="min-w-full divide-y divide-stone-200">
        <thead class="bg-stone-50">
          <tr>
            <th class="px-4 py-2 text-left text-xs font-medium text-stone-500 uppercase tracking-wider">Name</th>
            <th class="px-4 py-2 text-left text-xs font-medium text-stone-500 uppercase tracking-wider">Label</th>
            <th class="px-4 py-2 text-left text-xs font-medium text-stone-500 uppercase tracking-wider">Groups</th>
            <th class="px-4 py-2"></th>
          </tr>
        </thead>
        <tbody class="bg-white divide-y divide-stone-200 text-sm">
          <% @connection_types.each do |connection_type| %>
            <tr>
              <td class="px-4 py-3 whitespace-nowrap font-medium text-stone-900"><%= connection_type.name %></td>
              <td class="px-4 py-3 whitespace-nowrap text-stone-600"><%= connection_type.label.presence || "—" %></td>
              <td class="px-4 py-3 whitespace-nowrap text-stone-600"><%= connection_type.connection_groups.size %></td>
              <td class="px-4 py-3 whitespace-nowrap text-right space-x-2">
                <%= link_to "Edit", edit_admin_connection_type_path(connection_type), class: "text-stone-700 hover:text-stone-900 text-sm" %>
                <% if connection_type.connection_groups.empty? %>
                  <%= button_to "Delete", admin_connection_type_path(connection_type), method: :delete,
                        data: { turbo_confirm: "Delete this connection type?" },
                        class: "text-stone-700 hover:text-stone-900 text-sm" %>
                <% end %>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  <% else %>
    <div class="bg-white border border-stone-200 rounded p-4 text-center text-sm text-stone-500">
      No connection types yet.
    </div>
  <% end %>
</div>
