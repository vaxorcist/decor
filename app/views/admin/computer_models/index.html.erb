<%# decor/app/views/admin/computer_models/index.html.erb %>
<%# version 1.1 %>
<%# DRY: all context comes from @model_label, @model_label_plural, %>
<%# @device_type_key, @new_path, @edit_path_for, @delete_path_for %>
<%# set by Admin::ComputerModelsController#set_device_context. %>
<%# This same file serves both Computer Models and Appliance Models. %>
<div class="max-w-7xl mx-auto">
  <div class="flex justify-between items-center mb-4">
    <h1 class="text-2xl font-semibold"><%= @model_label %> Models</h1>
    <%= link_to "Add #{@model_label} Model", @new_path, class: button_classes(style: :primary) %>
  </div>

  <% if @computer_models.any? %>
    <div class="bg-white border border-stone-200 rounded">
      <table class="min-w-full divide-y divide-stone-200">
        <thead class="bg-stone-50">
          <tr>
            <th class="px-4 py-2 text-left text-xs font-medium text-stone-500 uppercase tracking-wider">Name</th>
            <%# Header reflects the page context: "Computers" or "Appliances" %>
            <th class="px-4 py-2 text-left text-xs font-medium text-stone-500 uppercase tracking-wider"><%= @model_label_plural %></th>
            <th class="px-4 py-2"></th>
          </tr>
        </thead>
        <tbody class="bg-white divide-y divide-stone-200 text-sm">
          <% @computer_models.each do |computer_model| %>
            <%# Count only computers/appliances matching this page's device type. %>
            <%# computers is eager-loaded; filter in memory via the enum string key. %>
            <% usage_count = computer_model.computers.count { |c| c.device_type == @device_type_key } %>
            <tr>
              <td class="px-4 py-3 whitespace-nowrap font-medium text-stone-900"><%= computer_model.name %></td>
              <td class="px-4 py-3 whitespace-nowrap text-stone-600"><%= usage_count %></td>
              <td class="px-4 py-3 whitespace-nowrap text-right space-x-2">
                <%= link_to "Edit", @edit_path_for.call(computer_model),
                      class: "text-stone-700 hover:text-stone-900 text-sm" %>
                <% if usage_count == 0 %>
                  <%= button_to "Delete", @delete_path_for.call(computer_model),
                        method: :delete,
                        data: { turbo_confirm: "Delete this #{@model_label.downcase} model?" },
                        class: "text-stone-700 hover:text-stone-900 text-sm" %>
                <% end %>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  <% else %>
    <div class="bg-white border border-stone-200 rounded p-4 text-center text-sm text-stone-500">
      No <%= @model_label.downcase %> models yet.
    </div>
  <% end %>
</div>
