<%# decor/app/views/admin/software_names/_form.html.erb %>
<%# version 1.0 %>
<%# Form partial for both new and edit actions. %>
<%# SoftwareName class name matches the :software_names route, so %>
<%# form_with model: [:admin, software_name] resolves correctly without any %>
<%# url: or scope: override. %>
<%# Fields: :name (required, max 40) and :description (optional, max 100). %>
<%= form_with model: [:admin, software_name], class: "space-y-4" do |f| %>
  <%= render "common/record_errors", record: software_name %>

  <div>
    <%= f.label :name, class: "block text-sm font-medium text-stone-700" %>
    <%= f.text_field :name, required: true, autofocus: true, class: field_classes %>
  </div>

  <div>
    <%= f.label :description, class: "block text-sm font-medium text-stone-700" %>
    <%= f.text_field :description, class: field_classes %>
  </div>

  <div class="flex gap-3">
    <%= f.submit class: button_classes(style: :primary) %>
    <%= link_to "Cancel", admin_software_names_path, class: button_classes(style: :secondary) %>
  </div>
<% end %>
