<%# decor/app/views/admin/software_names/index.html.erb %>
<%# version 1.0 %>
<%# Lists all software_name records with their software item counts. %>
<%# The "Items" count column and the restrict_with_error deletion guard mirror %>
<%# the pattern used in admin/component_conditions. %>
<%# Description is truncated at 60 chars for readability; a dash is shown when blank. %>
<div class="max-w-7xl mx-auto">
  <div class="flex justify-between items-center mb-4">
    <h1 class="text-2xl font-semibold">Software Names</h1>
    <%= link_to "Add Software Name", new_admin_software_name_path, class: button_classes(style: :primary) %>
  </div>

  <% if @software_names.any? %>
    <div class="bg-white border border-stone-200 rounded">
      <table class="min-w-full divide-y divide-stone-200">
        <thead class="bg-stone-50">
          <tr>
            <th class="px-4 py-2 text-left text-xs font-medium text-stone-500 uppercase tracking-wider">Name</th>
            <th class="px-4 py-2 text-left text-xs font-medium text-stone-500 uppercase tracking-wider">Description</th>
            <th class="px-4 py-2 text-left text-xs font-medium text-stone-500 uppercase tracking-wider">Items</th>
            <th class="px-4 py-2"></th>
          </tr>
        </thead>
        <tbody class="bg-white divide-y divide-stone-200 text-sm">
          <% @software_names.each do |software_name| %>
            <tr>
              <td class="px-4 py-3 whitespace-nowrap font-medium text-stone-900"><%= software_name.name %></td>
              <td class="px-4 py-3 text-stone-600"><%= truncate(software_name.description, length: 60) || "—" %></td>
              <td class="px-4 py-3 whitespace-nowrap text-stone-600"><%= software_name.software_items.size %></td>
              <td class="px-4 py-3 whitespace-nowrap text-right space-x-2">
                <%= link_to "Edit", edit_admin_software_name_path(software_name), class: "text-stone-700 hover:text-stone-900 text-sm" %>
                <% if software_name.software_items.empty? %>
                  <%= button_to "Delete", admin_software_name_path(software_name), method: :delete, data: { turbo_confirm: "Delete this software name?" }, class: "text-stone-700 hover:text-stone-900 text-sm" %>
                <% end %>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  <% else %>
    <div class="bg-white border border-stone-200 rounded p-4 text-center text-sm text-stone-500">
      No software names yet.
    </div>
  <% end %>
</div>
