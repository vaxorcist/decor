<%# decor/app/views/owners/components.html.erb - version 1.2 %>
<%# v1.2 (Session 38): Added Connections tab (inactive) to the tab strip. %>
<%# v1.1 (Session 26): Added Peripherals tab to the tab strip. %>
<%#   Tab strip now has four tabs matching owners/show.html.erb summary card grid: %>
<%#   Computers | Appliances | Peripherals | Components (this page, active). %>
<%#   All other content unchanged from v1.0. %>
<%# v1.0 (Session 23): New sub-page for the owner's components. %>
<%#   Renders the shared _profile partial, a three-tab strip to navigate between %>
<%#   the sub-pages, and the components table. %>
<%#   Table content, column layout, and barter guards extracted from %>
<%#   owners/show.html.erb v1.8. Column order unchanged: %>
<%#   Computer-Serial No. | Type | Description | Order No. | Serial No. | [Trade] %>
<%#   Tab strip highlights "Components" as the active tab. %>

<div class="max-w-7xl mx-auto">
  <%# Profile header + info panel %>
  <%= render "profile" %>

  <%# Tab strip — switches between the four owner sub-pages %>
  <%# Order mirrors the summary card grid in owners/show.html.erb v2.0: %>
  <%#   Computers | Appliances | Peripherals | Components %>
  <div class="flex gap-6 border-b border-stone-200 mb-6">
    <%= link_to "Computers",   computers_owner_path(@owner),
          class: "pb-2 -mb-px border-b-2 " \
                 "border-transparent text-stone-600 hover:text-stone-900" %>
    <%= link_to "Appliances",  appliances_owner_path(@owner),
          class: "pb-2 -mb-px border-b-2 " \
                 "border-transparent text-stone-600 hover:text-stone-900" %>
    <%= link_to "Peripherals", peripherals_owner_path(@owner),
          class: "pb-2 -mb-px border-b-2 " \
                 "border-transparent text-stone-600 hover:text-stone-900" %>
    <%= link_to "Components",  components_owner_path(@owner),
          class: "pb-2 -mb-px border-b-2 font-medium " \
                 "border-indigo-600 text-indigo-700" %>
    <%= link_to "Connections", connections_owner_path(@owner),
          class: "pb-2 -mb-px border-b-2 border-transparent text-stone-600 hover:text-stone-900" %>
  </div>

  <%# Section header %>
  <div class="flex justify-between items-center mb-3">
    <h2 class="text-lg font-semibold">Components (<%= @components.count %>)</h2>
    <% if Current.owner == @owner %>
      <%= link_to "Add Component", new_component_path, class: button_classes(style: :secondary) %>
    <% end %>
  </div>

  <% if @components.any? %>
    <div class="bg-white border border-stone-200 rounded overflow-auto"
         style="max-height: calc(100vh - 18rem);">
      <table class="min-w-full divide-y divide-stone-200">
        <thead class="bg-stone-50 sticky top-0 z-10">
          <tr>
            <%# Header renamed from "Computer" to "Computer-Serial No." (Session 19) %>
            <th class="px-4 py-2 text-left text-xs font-medium text-stone-500 uppercase tracking-wider">Computer-Serial No.</th>
            <th class="px-4 py-2 text-left text-xs font-medium text-stone-500 uppercase tracking-wider">Type</th>
            <%# Description before Order No. and Serial No. (Session 19) %>
            <th class="px-4 py-2 text-left text-xs font-medium text-stone-500 uppercase tracking-wider">Description</th>
            <th class="px-4 py-2 text-left text-xs font-medium text-stone-500 uppercase tracking-wider">Order No.</th>
            <th class="px-4 py-2 text-left text-xs font-medium text-stone-500 uppercase tracking-wider">Serial No.</th>
            <%# Trade header — visible to logged-in members only %>
            <% if logged_in? %>
              <th class="px-4 py-2 text-left text-xs font-medium text-stone-500 uppercase tracking-wider">Trade</th>
            <% end %>
            <th class="px-4 py-2"></th>
          </tr>
        </thead>
        <tbody class="bg-white divide-y divide-stone-200 text-sm">
          <% @components.each do |component| %>
            <tr class="hover:bg-stone-50">
              <%# Computer-Serial No. — "Model – serial" link, or "Spare" for unattached %>
              <td class="px-4 py-3 whitespace-nowrap text-stone-600">
                <% if component.computer %>
                  <%= link_to "#{component.computer.computer_model.name} \u2013 #{component.computer.serial_number}",
                        computer_path(component.computer),
                        class: "text-indigo-600 hover:text-indigo-900" %>
                <% else %>
                  <span class="text-stone-400">Spare</span>
                <% end %>
              </td>
              <%# Type — clickable, navigates to component show page %>
              <td class="px-4 py-3 whitespace-nowrap font-medium">
                <%= link_to component.component_type.name, component_path(component),
                      class: "text-indigo-600 hover:text-indigo-900" %>
              </td>
              <%# Description — truncated; moved before Order No. and Serial No. (Session 19) %>
              <td class="px-4 py-3 text-stone-600"><%= truncate(component.description, length: 20) || "—" %></td>
              <td class="px-4 py-3 whitespace-nowrap text-stone-600"><%= component.order_number || "—" %></td>
              <td class="px-4 py-3 whitespace-nowrap text-stone-600"><%= component.serial_number || "—" %></td>
              <%# Trade cell — visible to logged-in members only %>
              <% if logged_in? %>
                <td class="px-4 py-3 whitespace-nowrap">
                  <% if component.barter_status_offered? %>
                    <span class="text-green-700">Offered</span>
                  <% elsif component.barter_status_wanted? %>
                    <span class="text-amber-600">Wanted</span>
                  <% else %>
                    <span class="text-stone-400">—</span>
                  <% end %>
                </td>
              <% end %>
              <%# Actions — Edit and Delete shown to owner only %>
              <td class="px-4 py-3 whitespace-nowrap text-right">
                <% if Current.owner == @owner %>
                  <div class="flex items-center justify-end gap-3">
                    <%= link_to "Edit", edit_component_path(component),
                          class: "text-indigo-600 hover:text-indigo-900" %>
                    <%= button_to "Delete", component_path(component), method: :delete,
                          data: { turbo_confirm: "Delete this #{component.component_type.name}? This cannot be undone." },
                          params: { source: "owner" },
                          class: "text-red-600 hover:text-red-900 bg-transparent border-0 p-0 cursor-pointer",
                          form: { style: "display:inline" } %>
                  </div>
                <% end %>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  <% else %>
    <p class="text-sm text-stone-500">No components registered.</p>
  <% end %>
</div>
