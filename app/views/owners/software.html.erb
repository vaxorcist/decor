<%# decor/app/views/owners/software.html.erb - version 1.1 %>
<%# v1.1 (Session 46): Software feature Session D. %>
<%#   Added "+ Add Software" button in the section header — visible when the %>
<%#   logged-in owner is viewing their own page (Current.owner == @owner). %>
<%# v1.0 (Session 45): Software feature Session C — owner-facing read-only sub-page. %>
<%# Lists all software items belonging to this owner. %>
<%# %>
<%# Table columns: %>
<%#   Software | Version | Condition | Description | Installed On | Trade | Actions %>
<%# %>
<%# "Installed On" shows "Model – serial" link when computer_id is set, or %>
<%# an em-dash when the item is unattached (not installed on any hardware). %>
<%# Trade column visible to logged-in members only. %>
<%# Actions column (Edit / Delete) visible to the record owner only. %>
<%# %>
<%# Ordering: software_names.name ASC, then software_items.version ASC NULLS LAST. %>

<div class="max-w-7xl mx-auto">
  <%# Profile header + info panel (shared partial) %>
  <%= render "profile" %>

  <%# Tab strip — Software is the active tab. %>
  <div class="flex gap-6 border-b border-stone-200 mb-6">
    <%= link_to "Computers",   computers_owner_path(@owner),
          class: "pb-2 -mb-px border-b-2 border-transparent text-stone-600 hover:text-stone-900" %>
    <%= link_to "Peripherals", peripherals_owner_path(@owner),
          class: "pb-2 -mb-px border-b-2 border-transparent text-stone-600 hover:text-stone-900" %>
    <%= link_to "Components",  components_owner_path(@owner),
          class: "pb-2 -mb-px border-b-2 border-transparent text-stone-600 hover:text-stone-900" %>
    <%= link_to "Connections", connections_owner_path(@owner),
          class: "pb-2 -mb-px border-b-2 border-transparent text-stone-600 hover:text-stone-900" %>
    <%= link_to "Software",    software_owner_path(@owner),
          class: "pb-2 -mb-px border-b-2 font-medium border-indigo-600 text-indigo-700" %>
  </div>

  <%# Section header with item count and optional "+ Add" button %>
  <div class="flex justify-between items-center mb-3">
    <h2 class="text-lg font-semibold">Software (<%= @software_items.count %>)</h2>
    <% if Current.owner == @owner %>
      <%= link_to "+ Add Software", new_software_item_path,
            class: "text-sm text-indigo-600 hover:text-indigo-900" %>
    <% end %>
  </div>

  <% if @software_items.any? %>
    <div class="bg-white border border-stone-200 rounded overflow-auto"
         style="max-height: calc(100vh - 18rem);">
      <table class="min-w-full divide-y divide-stone-200">
        <thead class="bg-stone-50 sticky top-0 z-10">
          <tr>
            <th class="px-4 py-2 text-left text-xs font-medium text-stone-500 uppercase tracking-wider">Software</th>
            <th class="px-4 py-2 text-left text-xs font-medium text-stone-500 uppercase tracking-wider">Version</th>
            <th class="px-4 py-2 text-left text-xs font-medium text-stone-500 uppercase tracking-wider">Condition</th>
            <th class="px-4 py-2 text-left text-xs font-medium text-stone-500 uppercase tracking-wider">Description</th>
            <th class="px-4 py-2 text-left text-xs font-medium text-stone-500 uppercase tracking-wider">Installed On</th>
            <% if logged_in? %>
              <th class="px-4 py-2 text-left text-xs font-medium text-stone-500 uppercase tracking-wider">Trade</th>
            <% end %>
            <%# Actions column — only rendered when the current owner is viewing their own page %>
            <% if Current.owner == @owner %>
              <th class="px-4 py-2 text-left text-xs font-medium text-stone-500 uppercase tracking-wider">Actions</th>
            <% end %>
          </tr>
        </thead>
        <tbody class="bg-white divide-y divide-stone-200 text-sm">
          <% @software_items.each do |item| %>
            <tr class="hover:bg-stone-50">
              <%# Software name — clickable, navigates to software item show page %>
              <td class="px-4 py-3 whitespace-nowrap font-medium">
                <%= link_to item.software_name.name, software_item_path(item),
                      class: "text-indigo-600 hover:text-indigo-900" %>
              </td>
              <td class="px-4 py-3 whitespace-nowrap text-stone-600"><%= item.version || "—" %></td>
              <td class="px-4 py-3 whitespace-nowrap text-stone-600"><%= item.software_condition&.name || "—" %></td>
              <td class="px-4 py-3 text-stone-600"><%= truncate(item.description, length: 30) || "—" %></td>
              <%# Installed On — "Model – serial" link, or em-dash when unattached %>
              <td class="px-4 py-3 whitespace-nowrap text-stone-600">
                <% if item.computer %>
                  <%= link_to "#{item.computer.computer_model.name} \u2013 #{item.computer.serial_number}",
                        computer_path(item.computer),
                        class: "text-indigo-600 hover:text-indigo-900" %>
                <% else %>
                  <span class="text-stone-400">—</span>
                <% end %>
              </td>
              <% if logged_in? %>
                <td class="px-4 py-3 whitespace-nowrap">
                  <% if item.barter_status_offered? %>
                    <span class="text-green-700">Offered</span>
                  <% elsif item.barter_status_wanted? %>
                    <span class="text-amber-600">Wanted</span>
                  <% else %>
                    <span class="text-stone-400">—</span>
                  <% end %>
                </td>
              <% end %>
              <%# Edit / Delete — visible to the record owner only %>
              <% if Current.owner == @owner %>
                <td class="px-4 py-3 whitespace-nowrap">
                  <%= link_to "Edit", edit_software_item_path(item),
                        class: "text-indigo-600 hover:text-indigo-900 mr-3" %>
                  <%= link_to "Delete", software_item_path(item),
                        data: { turbo_method: :delete,
                                turbo_confirm: "Delete #{item.software_name.name}? This cannot be undone." },
                        class: "text-red-600 hover:text-red-900" %>
                </td>
              <% end %>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  <% else %>
    <p class="text-sm text-stone-500">No software registered.</p>
  <% end %>
</div>
