<%# decor/app/views/owners/peripherals.html.erb - version 1.3 %>
<%# v1.3 (Session 45): Software feature Session C. %>
<%#   Added Software tab (inactive) to the tab strip. %>
<%#   Tab order: Computers | Peripherals (active) | Components | Connections | Software. %>
<%# v1.2 (Session 41): Appliances → Peripherals merger Phase 2. %>
<%#   Removed "Appliances" tab from the tab strip (appliances_owner_path gone). %>
<%#   Tab order: Computers | Peripherals (active) | Components | Connections. %>
<%#   Peripherals now covers all device_type_peripheral? records — former %>
<%#   appliances were merged into this category in Session 41. %>
<%# v1.1 (Session 38): Added Connections tab (inactive) to the tab strip. %>
<%# v1.0 (Session 25): New sub-page for the owner's peripherals. %>

<div class="max-w-7xl mx-auto">
  <%# Profile header + info panel %>
  <%= render "profile" %>

  <%# Tab strip — switches between the five owner sub-pages.
      Active tab: border-indigo-600 + text-indigo-700 + font-medium.
      Inactive tabs: border-transparent + text-stone-600. %>
  <div class="flex gap-6 border-b border-stone-200 mb-6">
    <%= link_to "Computers",  computers_owner_path(@owner),
          class: "pb-2 -mb-px border-b-2 border-transparent text-stone-600 hover:text-stone-900" %>
    <%= link_to "Peripherals", peripherals_owner_path(@owner),
          class: "pb-2 -mb-px border-b-2 font-medium border-indigo-600 text-indigo-700" %>
    <%= link_to "Components", components_owner_path(@owner),
          class: "pb-2 -mb-px border-b-2 border-transparent text-stone-600 hover:text-stone-900" %>
    <%= link_to "Connections", connections_owner_path(@owner),
          class: "pb-2 -mb-px border-b-2 border-transparent text-stone-600 hover:text-stone-900" %>
    <%= link_to "Software",    software_owner_path(@owner),
          class: "pb-2 -mb-px border-b-2 border-transparent text-stone-600 hover:text-stone-900" %>
  </div>

  <%# Section header %>
  <div class="flex justify-between items-center mb-3">
    <h2 class="text-lg font-semibold">Peripherals (<%= @peripherals.count %>)</h2>
    <% if Current.owner == @owner %>
      <%= link_to "Add Peripheral", new_computer_path(device_type: "peripheral"),
            class: button_classes(style: :secondary) %>
    <% end %>
  </div>

  <% if @peripherals.any? %>
    <div class="bg-white border border-stone-200 rounded overflow-auto"
         style="max-height: calc(100vh - 18rem);">
      <table class="min-w-full divide-y divide-stone-200">
        <thead class="bg-stone-50 sticky top-0 z-10">
          <tr>
            <th class="px-4 py-2 text-left text-xs font-medium text-stone-500 uppercase tracking-wider">Model</th>
            <th class="px-4 py-2 text-left text-xs font-medium text-stone-500 uppercase tracking-wider">Order</th>
            <th class="px-4 py-2 text-left text-xs font-medium text-stone-500 uppercase tracking-wider">Serial</th>
            <th class="px-4 py-2 text-left text-xs font-medium text-stone-500 uppercase tracking-wider">Condition</th>
            <th class="px-4 py-2 text-left text-xs font-medium text-stone-500 uppercase tracking-wider">Status</th>
            <%# Trade header — visible to logged-in members only %>
            <% if logged_in? %>
              <th class="px-4 py-2 text-left text-xs font-medium text-stone-500 uppercase tracking-wider">Trade</th>
            <% end %>
            <th class="px-4 py-2"></th>
          </tr>
        </thead>
        <tbody class="bg-white divide-y divide-stone-200 text-sm">
          <% @peripherals.each do |peripheral| %>
            <tr class="hover:bg-stone-50">
              <%# Model — clickable; peripherals use the computers_* routes %>
              <td class="px-4 py-3 whitespace-nowrap font-medium">
                <%= link_to peripheral.computer_model.name, computer_path(peripheral),
                      class: "text-indigo-600 hover:text-indigo-900" %>
              </td>
              <td class="px-4 py-3 whitespace-nowrap text-stone-600"><%= peripheral.order_number || "—" %></td>
              <td class="px-4 py-3 whitespace-nowrap text-stone-600"><%= peripheral.serial_number %></td>
              <td class="px-4 py-3 whitespace-nowrap text-stone-600"><%= peripheral.computer_condition&.name || "—" %></td>
              <td class="px-4 py-3 whitespace-nowrap text-stone-600"><%= peripheral.run_status&.name || "—" %></td>
              <%# Trade cell — visible to logged-in members only %>
              <% if logged_in? %>
                <td class="px-4 py-3 whitespace-nowrap">
                  <% if peripheral.barter_status_offered? %>
                    <span class="text-green-700">Offered</span>
                  <% elsif peripheral.barter_status_wanted? %>
                    <span class="text-amber-600">Wanted</span>
                  <% else %>
                    <span class="text-stone-400">—</span>
                  <% end %>
                </td>
              <% end %>
              <%# Actions — Edit and Delete shown to owner only %>
              <td class="px-4 py-3 whitespace-nowrap text-right">
                <% if Current.owner == @owner %>
                  <div class="flex items-center justify-end gap-3">
                    <%= link_to "Edit", edit_computer_path(peripheral),
                          class: "text-indigo-600 hover:text-indigo-900" %>
                    <%= button_to "Delete", computer_path(peripheral), method: :delete,
                          data: { turbo_confirm: "Delete #{peripheral.computer_model.name} (#{peripheral.serial_number})? This cannot be undone." },
                          params: { source: "owner" },
                          class: "text-red-600 hover:text-red-900 bg-transparent border-0 p-0 cursor-pointer",
                          form: { style: "display:inline" } %>
                  </div>
                <% end %>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  <% else %>
    <p class="text-sm text-stone-500">No peripherals registered.</p>
  <% end %>
</div>
