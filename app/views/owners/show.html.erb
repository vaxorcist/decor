<%# decor/app/views/owners/show.html.erb - version 2.1 %>
<%# v2.1 (Session 38): Added Connections summary card (5th). %>
<%#   - Grid changed from grid-cols-4 to grid-cols-5. %>
<%#   - @connection_group_count loaded by owners_controller#show v1.8. %>
<%#   - Card links to connections_owner_path; owner sees "+ Add" link for new group. %>
<%# v2.0 (Session 25): Added Peripherals summary card. %>
<%#   - Grid changed from grid-cols-3 to grid-cols-4 to accommodate the new card. %>
<%#   - @peripheral_count loaded by owners_controller#show v1.7. %>
<%#   - Card order: Computers | Appliances | Peripherals | Components. %>
<%#   - "Add Peripheral" link pre-selects device_type: "peripheral" on the new form. %>
<%# v1.9 (Session 23): Replaced the three inline tables with a summary card view. %>
<%#   Profile header and info panel extracted to owners/_profile.html.erb. %>
<%#   Three cards (Computers / Appliances / Components) show item counts and link %>
<%#   to the corresponding sub-pages (/owners/:id/computers etc.). %>
<%#   Owner of the account also sees an "Add" link on each card. %>

<div class="max-w-5xl mx-auto">
  <%# Profile header + info panel (shared with sub-pages) %>
  <%= render "profile" %>

  <%# Section cards: one per collection, showing count + navigation.
      Five cards in a single row on standard viewports. %>
  <div class="grid grid-cols-5 gap-4">

    <%# Computers card %>
    <div class="bg-white border border-stone-200 rounded p-5">
      <div class="flex justify-between items-start mb-3">
        <h2 class="font-semibold text-stone-700">Computers</h2>
        <span class="text-2xl font-bold text-stone-300"><%= @computer_count %></span>
      </div>
      <div class="flex items-center justify-between">
        <%= link_to "View →", computers_owner_path(@owner),
              class: "text-sm text-indigo-600 hover:text-indigo-900" %>
        <% if Current.owner == @owner %>
          <%= link_to "+ Add", new_computer_path,
                class: "text-sm text-indigo-600 hover:text-indigo-900" %>
        <% end %>
      </div>
    </div>

    <%# Appliances card %>
    <div class="bg-white border border-stone-200 rounded p-5">
      <div class="flex justify-between items-start mb-3">
        <h2 class="font-semibold text-stone-700">Appliances</h2>
        <span class="text-2xl font-bold text-stone-300"><%= @appliance_count %></span>
      </div>
      <div class="flex items-center justify-between">
        <%= link_to "View →", appliances_owner_path(@owner),
              class: "text-sm text-indigo-600 hover:text-indigo-900" %>
        <% if Current.owner == @owner %>
          <%= link_to "+ Add", new_computer_path(device_type: "appliance"),
                class: "text-sm text-indigo-600 hover:text-indigo-900" %>
        <% end %>
      </div>
    </div>

    <%# Peripherals card %>
    <div class="bg-white border border-stone-200 rounded p-5">
      <div class="flex justify-between items-start mb-3">
        <h2 class="font-semibold text-stone-700">Peripherals</h2>
        <span class="text-2xl font-bold text-stone-300"><%= @peripheral_count %></span>
      </div>
      <div class="flex items-center justify-between">
        <%= link_to "View →", peripherals_owner_path(@owner),
              class: "text-sm text-indigo-600 hover:text-indigo-900" %>
        <% if Current.owner == @owner %>
          <%= link_to "+ Add", new_computer_path(device_type: "peripheral"),
                class: "text-sm text-indigo-600 hover:text-indigo-900" %>
        <% end %>
      </div>
    </div>

    <%# Components card %>
    <div class="bg-white border border-stone-200 rounded p-5">
      <div class="flex justify-between items-start mb-3">
        <h2 class="font-semibold text-stone-700">Components</h2>
        <span class="text-2xl font-bold text-stone-300"><%= @component_count %></span>
      </div>
      <div class="flex items-center justify-between">
        <%= link_to "View →", components_owner_path(@owner),
              class: "text-sm text-indigo-600 hover:text-indigo-900" %>
        <% if Current.owner == @owner %>
          <%= link_to "+ Add", new_component_path,
                class: "text-sm text-indigo-600 hover:text-indigo-900" %>
        <% end %>
      </div>
    </div>

    <%# Connections card — links to the new connections sub-page %>
    <div class="bg-white border border-stone-200 rounded p-5">
      <div class="flex justify-between items-start mb-3">
        <h2 class="font-semibold text-stone-700">Connections</h2>
        <span class="text-2xl font-bold text-stone-300"><%= @connection_group_count %></span>
      </div>
      <div class="flex items-center justify-between">
        <%= link_to "View →", connections_owner_path(@owner),
              class: "text-sm text-indigo-600 hover:text-indigo-900" %>
        <% if Current.owner == @owner %>
          <%= link_to "+ Add", new_owner_connection_group_path(@owner),
                class: "text-sm text-indigo-600 hover:text-indigo-900" %>
        <% end %>
      </div>
    </div>

  </div>
</div>
