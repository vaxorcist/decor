<%# decor/app/views/owners/connections.html.erb - version 1.0 %>
<%# Session 38: New owner sub-page — Connections. %>
<%# Replaces the old /owners/:id/connection_groups standalone index. %>
<%# %>
<%# Table layout (one row per port, grouped): %>
<%#   First row of each group: CONNECTION ID | TYPE | CONNECTION LABEL | PORT ID | CONNECTS | PORT LABEL | Edit Delete %>
<%#   Subsequent rows:         (blank)       | (b)  | (blank)          | PORT ID | CONNECTS | PORT LABEL | (blank) %>
<%# Groups are ordered by owner_group_id; ports within each group by owner_member_id. %>
<%# A heavier top border (border-t-2 border-stone-300) separates consecutive groups. %>
<%# %>
<%# @connection_groups is loaded in owners_controller#connections (v1.8) with %>
<%# eager-loaded connection_type and connection_members (with computer+model). %>
<%# Members are sorted in memory (.sort_by) — no extra DB queries per row. %>

<% content_for :title, "Connections" %>

<div class="max-w-7xl mx-auto">
  <%# Profile header + info panel (shared partial) %>
  <%= render "profile" %>

  <%# Tab strip — Connections is the active tab. %>
  <%# Active:   border-indigo-600 + text-indigo-700 + font-medium. %>
  <%# Inactive: border-transparent + text-stone-600. %>
  <div class="flex gap-6 border-b border-stone-200 mb-6">
    <%= link_to "Computers",   computers_owner_path(@owner),
          class: "pb-2 -mb-px border-b-2 border-transparent text-stone-600 hover:text-stone-900" %>
    <%= link_to "Appliances",  appliances_owner_path(@owner),
          class: "pb-2 -mb-px border-b-2 border-transparent text-stone-600 hover:text-stone-900" %>
    <%= link_to "Peripherals", peripherals_owner_path(@owner),
          class: "pb-2 -mb-px border-b-2 border-transparent text-stone-600 hover:text-stone-900" %>
    <%= link_to "Components",  components_owner_path(@owner),
          class: "pb-2 -mb-px border-b-2 border-transparent text-stone-600 hover:text-stone-900" %>
    <%= link_to "Connections", connections_owner_path(@owner),
          class: "pb-2 -mb-px border-b-2 font-medium border-indigo-600 text-indigo-700" %>
  </div>

  <%# Section header %>
  <div class="flex justify-between items-center mb-3">
    <h2 class="text-lg font-semibold">Connections (<%= @connection_groups.count %>)</h2>
    <% if Current.owner == @owner %>
      <%= link_to "Add Connection", new_owner_connection_group_path(@owner),
            class: button_classes(style: :secondary) %>
    <% end %>
  </div>

  <% if @connection_groups.any? %>
    <div class="bg-white border border-stone-200 rounded overflow-auto"
         style="max-height: calc(100vh - 18rem);">
      <table class="min-w-full divide-y divide-stone-200">
        <thead class="bg-stone-50 sticky top-0 z-10">
          <tr>
            <th class="px-4 py-2 text-left text-xs font-medium text-stone-500 uppercase tracking-wider">Connection ID</th>
            <th class="px-4 py-2 text-left text-xs font-medium text-stone-500 uppercase tracking-wider">Type</th>
            <th class="px-4 py-2 text-left text-xs font-medium text-stone-500 uppercase tracking-wider">Connection Label</th>
            <th class="px-4 py-2 text-left text-xs font-medium text-stone-500 uppercase tracking-wider">Port ID</th>
            <th class="px-4 py-2 text-left text-xs font-medium text-stone-500 uppercase tracking-wider">Connects</th>
            <th class="px-4 py-2 text-left text-xs font-medium text-stone-500 uppercase tracking-wider">Port Label</th>
            <th class="px-4 py-2"></th>
          </tr>
        </thead>
        <tbody class="bg-white text-sm">

          <% @connection_groups.each_with_index do |group, group_idx| %>
            <%# Sort members by owner_member_id using the preloaded in-memory collection
                (avoid firing a new DB query per group). %>
            <% members = group.connection_members.sort_by(&:owner_member_id) %>

            <% members.each_with_index do |member, member_idx| %>
              <%# Heavier border at the top of every group except the very first,
                  to visually separate groups from one another. %>
              <tr class="hover:bg-stone-50 <%= 'border-t-2 border-stone-300' if group_idx > 0 && member_idx == 0 %> <%= 'border-t border-stone-100' if member_idx > 0 %>">

                <%# ── Group columns — filled only on the first member row ── %>
                <% if member_idx == 0 %>
                  <td class="px-4 py-3 whitespace-nowrap text-stone-600 align-top font-medium">
                    <%= group.owner_group_id %>
                  </td>
                  <td class="px-4 py-3 whitespace-nowrap text-stone-600 align-top">
                    <%= group.connection_type&.name || "—" %>
                  </td>
                  <td class="px-4 py-3 whitespace-nowrap text-stone-600 align-top">
                    <%= group.label.presence || "—" %>
                  </td>
                <% else %>
                  <%# Subsequent rows: group columns intentionally blank %>
                  <td></td>
                  <td></td>
                  <td></td>
                <% end %>

                <%# ── Port columns — filled on every row ── %>
                <td class="px-4 py-3 whitespace-nowrap text-stone-600">
                  <%= member.owner_member_id %>
                </td>
                <td class="px-4 py-3 text-stone-600">
                  <%# Device link: "Model Name – SN serial_number" %>
                  <%= link_to "#{member.computer.computer_model.name} – #{member.computer.serial_number}",
                              computer_path(member.computer),
                              class: "text-indigo-600 hover:text-indigo-900" %>
                </td>
                <td class="px-4 py-3 text-stone-600">
                  <%= member.label.presence || "" %>
                </td>

                <%# ── Actions — Edit / Delete on the first row only, owner only ── %>
                <td class="px-4 py-3 whitespace-nowrap text-right align-top">
                  <% if member_idx == 0 && Current.owner == @owner %>
                    <div class="flex items-center justify-end gap-3">
                      <%= link_to "Edit",
                                  edit_owner_connection_group_path(@owner, group),
                                  class: "text-indigo-600 hover:text-indigo-900" %>
                      <%= button_to "Delete",
                                    owner_connection_group_path(@owner, group),
                                    method: :delete,
                                    data: { turbo_confirm: "Delete connection #{group.owner_group_id}? This cannot be undone." },
                                    class: "text-red-600 hover:text-red-900 bg-transparent border-0 p-0 cursor-pointer",
                                    form: { style: "display:inline" } %>
                    </div>
                  <% end %>
                </td>

              </tr>
            <% end %>
          <% end %>

        </tbody>
      </table>
    </div>
  <% else %>
    <p class="text-sm text-stone-500">No connections recorded yet.</p>
  <% end %>
</div>
