<%# decor/app/views/layouts/admin.html.erb %>
<%# version 2.0 %>
<%# v2.0 (Session 41): Appliances → Peripherals merger Phase 2. %>
<%#   Removed "Appliances" dropdown entirely (admin_appliance_models_path gone). %>
<%#   Peripheral Models remain under the existing Peripherals dropdown. %>
<%# v1.9 (Session 33): Added "Connections" dropdown after Components. %>
<%# v1.8 (Session 25): Added "Peripherals" dropdown between Appliances and Components. %>
<%# v1.7 (Session 24): Import/Export dropdown renamed to "Imports/Exports". %>
<%# v1.6 (Session 23): Owners dropdown: added "Invite Owner" link. %>
<%# v1.5 (Session 20): Texts dropdown simplified to two items. %>
<%# v1.4 (Session 18): Added "Texts" dropdown. %>
<%# v1.3: Appliance Models link activated. %>
<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "Admin - DEC Owner's Registry" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="application-name" content="Decor">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <%= yield :head %>
    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">
    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body class="bg-stone-100 min-h-screen text-stone-900">
    <nav class="bg-white border-b border-stone-200">
      <div class="mx-auto max-w-7xl px-6">
        <div class="flex justify-between h-14">

          <%# ── Left side: dropdown menus ───────────────────────────────── %>
          <div class="flex items-center space-x-1 text-sm">

            <%# ── Owners ─────────────────────────────────────────────────── %>
            <div class="relative" data-controller="dropdown">
              <button data-action="click->dropdown#toggle"
                      class="flex items-center gap-1 px-3 py-2 font-medium text-stone-700
                             hover:text-stone-900 hover:bg-stone-50 rounded">
                Owners
                <svg class="w-3 h-3 mt-0.5" fill="none" stroke="currentColor"
                     viewBox="0 0 24 24" stroke-width="2.5">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/>
                </svg>
              </button>
              <div data-dropdown-target="menu"
                   class="hidden absolute top-full left-0 mt-1 bg-white border border-stone-200
                          rounded shadow-md py-1 z-50 min-w-max">
                <%= link_to "Manage Owners", admin_owners_path,
                      class: "block px-4 py-2 text-sm text-stone-700 hover:bg-stone-50 hover:text-stone-900" %>
                <%= link_to "Invite Owner", new_admin_invite_path,
                      class: "block px-4 py-2 text-sm text-stone-700 hover:bg-stone-50 hover:text-stone-900" %>
                <%= link_to "Pending Invites", admin_invites_path,
                      class: "block px-4 py-2 text-sm text-stone-700 hover:bg-stone-50 hover:text-stone-900" %>
              </div>
            </div>

            <%# ── Computers ───────────────────────────────────────────────── %>
            <div class="relative" data-controller="dropdown">
              <button data-action="click->dropdown#toggle"
                      class="flex items-center gap-1 px-3 py-2 font-medium text-stone-700
                             hover:text-stone-900 hover:bg-stone-50 rounded">
                Computers
                <svg class="w-3 h-3 mt-0.5" fill="none" stroke="currentColor"
                     viewBox="0 0 24 24" stroke-width="2.5">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/>
                </svg>
              </button>
              <div data-dropdown-target="menu"
                   class="hidden absolute top-full left-0 mt-1 bg-white border border-stone-200
                          rounded shadow-md py-1 z-50 min-w-max">
                <%= link_to "Computer Models", admin_computer_models_path,
                      class: "block px-4 py-2 text-sm text-stone-700 hover:bg-stone-50 hover:text-stone-900" %>
                <%= link_to "Computer Conditions", admin_conditions_path,
                      class: "block px-4 py-2 text-sm text-stone-700 hover:bg-stone-50 hover:text-stone-900" %>
                <%= link_to "Run Statuses", admin_run_statuses_path,
                      class: "block px-4 py-2 text-sm text-stone-700 hover:bg-stone-50 hover:text-stone-900" %>
              </div>
            </div>

            <%# ── Peripherals ─────────────────────────────────────────────── %>
            <%# Covers all peripheral models — former appliance models were merged %>
            <%# into this category in Session 41. %>
            <div class="relative" data-controller="dropdown">
              <button data-action="click->dropdown#toggle"
                      class="flex items-center gap-1 px-3 py-2 font-medium text-stone-700
                             hover:text-stone-900 hover:bg-stone-50 rounded">
                Peripherals
                <svg class="w-3 h-3 mt-0.5" fill="none" stroke="currentColor"
                     viewBox="0 0 24 24" stroke-width="2.5">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/>
                </svg>
              </button>
              <div data-dropdown-target="menu"
                   class="hidden absolute top-full left-0 mt-1 bg-white border border-stone-200
                          rounded shadow-md py-1 z-50 min-w-max">
                <%= link_to "Peripheral Models", admin_peripheral_models_path,
                      class: "block px-4 py-2 text-sm text-stone-700 hover:bg-stone-50 hover:text-stone-900" %>
              </div>
            </div>

            <%# ── Components ──────────────────────────────────────────────── %>
            <div class="relative" data-controller="dropdown">
              <button data-action="click->dropdown#toggle"
                      class="flex items-center gap-1 px-3 py-2 font-medium text-stone-700
                             hover:text-stone-900 hover:bg-stone-50 rounded">
                Components
                <svg class="w-3 h-3 mt-0.5" fill="none" stroke="currentColor"
                     viewBox="0 0 24 24" stroke-width="2.5">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/>
                </svg>
              </button>
              <div data-dropdown-target="menu"
                   class="hidden absolute top-full left-0 mt-1 bg-white border border-stone-200
                          rounded shadow-md py-1 z-50 min-w-max">
                <%= link_to "Component Types", admin_component_types_path,
                      class: "block px-4 py-2 text-sm text-stone-700 hover:bg-stone-50 hover:text-stone-900" %>
                <%= link_to "Component Conditions", admin_component_conditions_path,
                      class: "block px-4 py-2 text-sm text-stone-700 hover:bg-stone-50 hover:text-stone-900" %>
              </div>
            </div>

            <%# ── Connections ─────────────────────────────────────────────── %>
            <div class="relative" data-controller="dropdown">
              <button data-action="click->dropdown#toggle"
                      class="flex items-center gap-1 px-3 py-2 font-medium text-stone-700
                             hover:text-stone-900 hover:bg-stone-50 rounded">
                Connections
                <svg class="w-3 h-3 mt-0.5" fill="none" stroke="currentColor"
                     viewBox="0 0 24 24" stroke-width="2.5">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/>
                </svg>
              </button>
              <div data-dropdown-target="menu"
                   class="hidden absolute top-full left-0 mt-1 bg-white border border-stone-200
                          rounded shadow-md py-1 z-50 min-w-max">
                <%= link_to "Connection Types", admin_connection_types_path,
                      class: "block px-4 py-2 text-sm text-stone-700 hover:bg-stone-50 hover:text-stone-900" %>
              </div>
            </div>

            <%# ── Imports/Exports ─────────────────────────────────────────── %>
            <div class="relative" data-controller="dropdown">
              <button data-action="click->dropdown#toggle"
                      class="flex items-center gap-1 px-3 py-2 font-medium text-stone-700
                             hover:text-stone-900 hover:bg-stone-50 rounded">
                Imports/Exports
                <svg class="w-3 h-3 mt-0.5" fill="none" stroke="currentColor"
                     viewBox="0 0 24 24" stroke-width="2.5">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/>
                </svg>
              </button>
              <div data-dropdown-target="menu"
                   class="hidden absolute top-full left-0 mt-1 bg-white border border-stone-200
                          rounded shadow-md py-1 z-50 min-w-max">
                <%= link_to "Exports", admin_data_transfer_path(anchor: "export"),
                      class: "block px-4 py-2 text-sm text-stone-700 hover:bg-stone-50 hover:text-stone-900" %>
                <%= link_to "Imports", admin_data_transfer_path(anchor: "import"),
                      class: "block px-4 py-2 text-sm text-stone-700 hover:bg-stone-50 hover:text-stone-900" %>
              </div>
            </div>

            <%# ── Texts ───────────────────────────────────────────────────── %>
            <%# Two generic actions — key selected on the target page, not here. %>
            <div class="relative" data-controller="dropdown">
              <button data-action="click->dropdown#toggle"
                      class="flex items-center gap-1 px-3 py-2 font-medium text-stone-700
                             hover:text-stone-900 hover:bg-stone-50 rounded">
                Texts
                <svg class="w-3 h-3 mt-0.5" fill="none" stroke="currentColor"
                     viewBox="0 0 24 24" stroke-width="2.5">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/>
                </svg>
              </button>
              <div data-dropdown-target="menu"
                   class="hidden absolute top-full left-0 mt-1 bg-white border border-stone-200
                          rounded shadow-md py-1 z-50 min-w-max">
                <%= link_to "Upload Text", new_admin_site_text_path,
                      class: "block px-4 py-2 text-sm text-stone-700 hover:bg-stone-50 hover:text-stone-900" %>
                <%= link_to "Delete Text", delete_confirm_admin_site_texts_path,
                      class: "block px-4 py-2 text-sm text-stone-700 hover:bg-stone-50 hover:text-stone-900" %>
              </div>
            </div>

          </div><%# end left side %>

          <%# ── Right side: Exit Admin ──────────────────────────────────── %>
          <div class="flex items-center text-sm">
            <%= link_to "Exit Admin", root_path,
                  class: "font-medium text-stone-700 hover:text-stone-900" %>
          </div>

        </div>
      </div>
    </nav>

    <% if flash[:notice] %>
      <div class="bg-stone-50 border-b border-stone-200">
        <div class="mx-auto max-w-7xl px-6 py-3 text-sm text-stone-700 border-l-2 border-stone-400">
          <%= flash[:notice] %>
        </div>
      </div>
    <% end %>

    <% if flash[:alert] %>
      <div class="bg-stone-50 border-b border-stone-200">
        <div class="mx-auto max-w-7xl px-6 py-3 text-sm text-stone-700 border-l-2 border-stone-600">
          <%= flash[:alert] %>
        </div>
      </div>
    <% end %>

    <main class="mx-auto max-w-7xl px-6 py-6">
      <%= yield %>
    </main>
  </body>
</html>
