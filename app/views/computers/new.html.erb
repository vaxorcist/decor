<%# decor/app/views/computers/new.html.erb - version 1.4 %>
<%# v1.4 (Session 18): Heading now uses @computer.device_type.capitalize for %>
<%#   consistency with edit.html.erb (v1.3). Defaults to "Add Computer" since %>
<%#   Computer.new defaults device_type to 0 (computer). %>
<%# v1.3 (Session 10): Added Stimulus Back button below form, matching components/edit pattern. %>

<div class="max-w-5xl mx-auto">
  <h1 class="text-2xl font-semibold mb-4">Add <%= @computer.device_type.capitalize %></h1>

  <div class="mb-4 p-3 bg-blue-50 border border-blue-200 rounded text-sm text-blue-800">
    <strong>Required fields:</strong> Model and Serial Number.
    Components can be added after saving.
  </div>

  <%= render "form", computer: @computer %>

  <%# Stimulus Back button — history.back() primary; computers index as fallback %>
  <div class="mt-4">
    <a href="#"
       data-controller="back"
       data-back-fallback-url-value="<%= computers_path %>"
       data-action="click->back#go"
       class="text-sm text-stone-700 hover:text-stone-900">← Back</a>
  </div>
</div>
