<%# decor/app/views/computers/index.html.erb - version 1.7 %>
<%# v1.7 (Session 17): All context-specific values now come from controller instance %>
<%#   variables set by set_device_context, so this template serves both the %>
<%#   /computers and /appliances routes without duplication: %>
<%#     @page_title     — heading text ("Computers" or "Appliances") %>
<%#     @index_path     — load_more path and turbo stream target %>
<%#     @turbo_tbody_id — tbody id used by turbo_stream.append %>
<%#     @device_context — controls Type column header visibility %>
<%# v1.6: Added "Type" column header between Model and Order Number. %>
<%# v1.5: Renamed Description column header to Order Number. %>

<div class="px-4">
  <h1 class="text-2xl font-semibold mb-4 sticky top-0 bg-white z-10 py-2"><%= @page_title %></h1>

  <div class="grid grid-cols-1 md:grid-cols-4 gap-4">
    <div class="sticky top-16 self-start">
      <%= render "filters" %>
    </div>

    <div class="col-span-3 self-start">
      <% if @page.records.any? %>
        <div class="bg-white border border-stone-200 rounded overflow-auto" style="max-height: calc(100vh - 8rem);">
          <table class="min-w-full divide-y divide-stone-200">
            <thead class="bg-stone-50 sticky top-0 z-10">
              <tr>
                <th class="px-4 py-2 text-left text-xs font-medium text-stone-500 uppercase tracking-wider">Owner</th>
                <th class="px-4 py-2 text-left text-xs font-medium text-stone-500 uppercase tracking-wider">Model</th>
                <%# Type column is redundant on the Appliances page — every row is an appliance. %>
                <% unless @device_context == "appliance" %>
                  <th class="px-4 py-2 text-left text-xs font-medium text-stone-500 uppercase tracking-wider">Type</th>
                <% end %>
                <th class="px-4 py-2 text-left text-xs font-medium text-stone-500 uppercase tracking-wider">Order Number</th>
                <th class="px-4 py-2 text-left text-xs font-medium text-stone-500 uppercase tracking-wider">Serial Number</th>
                <th class="px-4 py-2 text-left text-xs font-medium text-stone-500 uppercase tracking-wider">Condition</th>
                <th class="px-4 py-2 text-left text-xs font-medium text-stone-500 uppercase tracking-wider">Run Status</th>
                <th class="px-4 py-2"></th>
              </tr>
            </thead>
            <tbody id="<%= @turbo_tbody_id %>" class="bg-white divide-y divide-stone-200 text-sm">
              <% @page.records.each do |computer| %>
                <%= render "computer", computer: computer %>
              <% end %>
            </tbody>
          </table>
        </div>
      <% else %>
        <%= empty_state("No #{@page_title.downcase} found matching your search") %>
      <% end %>
    </div>

    <%= render "shared/load_more", id: @load_more_id, page: @page, path: @index_path %>
  </div>

</div>
