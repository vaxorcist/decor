<%# decor/app/views/computers/_form.html.erb - version 2.5 %>
<%# v2.5 (Session 21): Added barter_status field and Trade column in component sub-table. %>
<%#   Line 2 now grid-cols-3: Condition | Run Status | Trade Status. %>
<%#   barter_status select uses Computer.barter_statuses keys to build options so the %>
<%#   labels are human-readable rather than raw integers. %>
<%#   Component sub-table gains a "Trade" column (after Condition) showing each %>
<%#   component's barter_status — members only context (form always requires login). %>
<%# v2.4 (Session 20): Removed visible device_type selector; hidden field instead. %>
<%#   Line 2 reverted from grid-cols-3 to grid-cols-2. %>
<%# v2.3 (Session 19): Components table column changes. %>
<%# v2.2 (Session 18): Model selector scoped to computer.device_type. %>
<%# v2.0 (Session 17): All hardcoded "Computer" strings replaced with device_type.capitalize. %>

<%= form_with model: computer, class: "space-y-4", style: "width: 80%;" do |f| %>
  <%= render "common/record_errors", record: computer %>

  <%# device_type is fixed at creation time — not editable after the record exists. %>
  <%# Hidden field carries the correct type through on create; on edit it echoes the %>
  <%# current value so the param is present but causes no change. %>
  <%= f.hidden_field :device_type %>

  <!-- Line 1: Model | Order Number | Serial Number -->
  <div class="grid grid-cols-3 gap-4">
    <div>
      <%= f.label :computer_model_id, class: "block text-sm font-medium text-stone-700" do %>
        Model <span class="text-red-600">*</span>
      <% end %>
      <%# Model list is scoped to the record's current device_type so appliance forms %>
      <%# show only appliance models and computer forms show only computer models. %>
      <%= f.collection_select :computer_model_id, ComputerModel.where(device_type: computer.device_type).order(:name), :id, :name, { prompt: "Select a model" }, class: field_classes %>
      <p class="mt-1 text-xs text-stone-500">Select from list.</p>
    </div>

    <div>
      <%= f.label :order_number, "Order Number", class: "block text-sm font-medium text-stone-700" %>
      <%= f.text_field :order_number, maxlength: 20, class: field_classes %>
      <p class="mt-1 text-xs text-stone-500">Maximum 20 characters.</p>
    </div>

    <div>
      <%= f.label :serial_number, class: "block text-sm font-medium text-stone-700" do %>
        Serial Number <span class="text-red-600">*</span>
      <% end %>
      <%= f.text_field :serial_number, maxlength: 20, class: field_classes %>
      <p class="mt-1 text-xs text-stone-500">Maximum 20 characters.</p>
    </div>
  </div>

  <!-- Line 2: Condition | Run Status | Trade Status -->
  <%# Expanded from grid-cols-2 to grid-cols-3 to accommodate barter_status. %>
  <%# The form is only accessible to logged-in owners so no logged_in? guard is needed. %>
  <div class="grid grid-cols-3 gap-4">
    <div>
      <%= f.label :computer_condition_id, "Condition", class: "block text-sm font-medium text-stone-700" %>
      <%= f.collection_select :computer_condition_id, ComputerCondition.order(:name), :id, :name, { prompt: "Select a condition" }, class: field_classes %>
    </div>

    <div>
      <%= f.label :run_status_id, "Run Status", class: "block text-sm font-medium text-stone-700" %>
      <%= f.collection_select :run_status_id, RunStatus.order(:name), :id, :name, { prompt: "Select a run status" }, class: field_classes %>
    </div>

    <div>
      <%= f.label :barter_status, "Trade Status", class: "block text-sm font-medium text-stone-700" %>
      <%# Build options from the enum hash so labels are human-readable. %>
      <%# Keys: no_barter → "No Trade", offered → "Offered", wanted → "Wanted". %>
      <%= f.select :barter_status,
            [["No Trade", "no_barter"], ["Offered", "offered"], ["Wanted", "wanted"]],
            {},
            class: field_classes %>
      <p class="mt-1 text-xs text-stone-500">Visible to members only.</p>
    </div>
  </div>

  <!-- Line 3: History — 3 rows -->
  <div>
    <%= f.label :history, class: "block text-sm font-medium text-stone-700" %>
    <%= f.text_area :history, rows: 3, style: "min-height: 4.5rem;", class: field_classes %>
    <p class="mt-1 text-xs text-stone-500">Provenance, previous owners, how you acquired it, etc.</p>
  </div>

  <%# Button row — submit + secondary actions + Back button %>
  <%# f.submit label is explicit to avoid the Rails default "Create/Update Computer" %>
  <%# regardless of device_type. %>
  <div class="flex gap-3 items-center">
    <%= f.submit "#{computer.persisted? ? "Update" : "Create"} #{computer.device_type.capitalize}", class: button_classes(style: :primary) %>
    <% unless computer.persisted? %>
      <%= f.submit "Create and add another", name: "add_another", class: button_classes(style: :secondary) %>
    <% end %>
    <%# "Done" instead of "Cancel" — no implication of reverting a prior action %>
    <%= link_to "Done", (computer.persisted? ? computer_path(computer) : computers_path), class: button_classes(style: :secondary) %>
    <%# Stimulus Back button — history.back() primary; fixed fallback for direct/bookmarked URLs %>
    <a href="#"
       data-controller="back"
       data-back-fallback-url-value="<%= computer.persisted? ? computer_path(computer) : computers_path %>"
       data-action="click->back#go"
       class="text-sm text-stone-700 hover:text-stone-900">← Back</a>
  </div>
<% end %>

<%# ─────────────────────────────────────────────────────────────────────────── %>
<%# Component section — outside the computer form (nested forms are invalid HTML) %>
<%# Only shown for existing computers/appliances (new record has no id yet) %>
<%# Full width: inherits max-w-5xl from the edit.html.erb container %>
<%# ─────────────────────────────────────────────────────────────────────────── %>
<% if computer.persisted? %>
  <hr class="my-8 border-stone-200" />

  <%# Add / Edit [Device]'s Component — shown ABOVE the component list %>
  <div class="mb-8">
    <% if @edit_component %>
      <h2 class="text-xl font-semibold mb-4">Edit <%= computer.device_type.capitalize %>'s Component</h2>
      <%= render "computer_component_form", component: @edit_component, computer: computer %>
    <% else %>
      <h2 class="text-xl font-semibold mb-4">Add <%= computer.device_type.capitalize %>'s Component</h2>
      <%= render "computer_component_form", component: @new_component, computer: computer %>
    <% end %>
  </div>

  <%# [Device]'s Components list — below the add/edit form %>
  <%# Column order: Type | Description | Order No. | Serial No. | Condition | Trade | Actions %>
  <div>
    <h2 class="text-xl font-semibold mb-4"><%= computer.device_type.capitalize %>'s Components</h2>

    <% if computer.components.any? %>
      <div class="bg-white border border-stone-200 rounded overflow-auto">
        <table class="min-w-full divide-y divide-stone-200">
          <thead class="bg-stone-50">
            <tr>
              <th class="px-4 py-2 text-left text-xs font-medium text-stone-500 uppercase tracking-wider">Type</th>
              <th class="px-4 py-2 text-left text-xs font-medium text-stone-500 uppercase tracking-wider">Description</th>
              <th class="px-4 py-2 text-left text-xs font-medium text-stone-500 uppercase tracking-wider">Order No.</th>
              <th class="px-4 py-2 text-left text-xs font-medium text-stone-500 uppercase tracking-wider">Serial No.</th>
              <th class="px-4 py-2 text-left text-xs font-medium text-stone-500 uppercase tracking-wider">Condition</th>
              <%# Trade column — always visible here (form requires login). %>
              <th class="px-4 py-2 text-left text-xs font-medium text-stone-500 uppercase tracking-wider">Trade</th>
              <th class="px-4 py-2"></th>
            </tr>
          </thead>
          <tbody class="bg-white divide-y divide-stone-200 text-sm">
            <% computer.components.includes(:component_type, :component_condition).each do |component| %>
              <tr class="hover:bg-stone-50">
                <%# Type — clickable, navigates to component show page %>
                <td class="px-4 py-3 whitespace-nowrap">
                  <%= link_to component.component_type.name, component_path(component), class: "text-indigo-600 hover:text-indigo-900" %>
                </td>
                <%# Description — truncated to prevent layout overflow %>
                <td class="px-4 py-3 text-stone-600" style="max-width: 250px;">
                  <div class="truncate"><%= component.description.presence || "—" %></div>
                </td>
                <%# Order No. %>
                <td class="px-4 py-3 whitespace-nowrap text-stone-600"><%= component.order_number.presence || "—" %></td>
                <%# Serial No. — component's own serial number %>
                <td class="px-4 py-3 whitespace-nowrap text-stone-600"><%= component.serial_number.presence || "—" %></td>
                <%# Condition %>
                <td class="px-4 py-3 whitespace-nowrap text-stone-600"><%= component.component_condition&.condition || "—" %></td>
                <%# Trade (barter_status) — green for offered, amber for wanted, dash for no_barter %>
                <td class="px-4 py-3 whitespace-nowrap">
                  <% if component.barter_status_offered? %>
                    <span class="text-green-700">Offered</span>
                  <% elsif component.barter_status_wanted? %>
                    <span class="text-amber-600">Wanted</span>
                  <% else %>
                    <span class="text-stone-400">—</span>
                  <% end %>
                </td>
                <%# Edit and Delete side by side %>
                <td class="px-4 py-3 whitespace-nowrap text-right">
                  <div class="flex justify-end gap-4">
                    <%= link_to "Edit",
                          edit_computer_path(computer, component_id: component.id),
                          class: "text-indigo-600 hover:text-indigo-900" %>
                    <%= button_to "Delete",
                          component_path(component),
                          method: :delete,
                          params: { source: "computer" },
                          form: { data: { turbo_confirm: "Delete this component? This cannot be undone." } },
                          class: "text-red-600 hover:text-red-900 bg-transparent border-0 cursor-pointer p-0" %>
                  </div>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    <% else %>
      <p class="text-stone-500 text-sm">No components added yet.</p>
    <% end %>
  </div>
<% end %>
