<%# decor/app/views/computers/show.html.erb - version 2.1 %>
<%# v2.1 (Session 38): Connections section redesigned — multi-row table. %>
<%#   Columns: CONNECTION ID | TYPE | CONNECTION LABEL | PORT ID | CONNECTS | PORT LABEL. %>
<%#   First row of each group shows all group columns; subsequent rows show only %>
<%#   the port columns (PORT ID, CONNECTS, PORT LABEL). %>
<%#   Groups ordered by owner_group_id; ports by owner_member_id. %>
<%#   Controller (v1.18) updated eager-load to include connection_members with computer+model. %>
<%# v2.0 (Session 36): Connections Type column now always shows connection_type.name. %>
<%# v1.9 (Session 35): Brakeman fix — peer links built with safe_join. %>
<%# v1.8 (Session 34): Added read-only Connections section. %>
<%# v1.7 (Session 22): Added Trade Status field. %>

<div class="max-w-7xl mx-auto">

  <%# ── Header: title + owner (left), Edit/Delete (right, owner/admin only) ── %>
  <div class="flex justify-between items-start mb-4">
    <div>
      <h1 class="text-2xl font-semibold"><%= @computer.computer_model.name %></h1>
      <p class="text-sm text-stone-600">Owned by <%= link_to @computer.owner.user_name, @computer.owner, class: "font-medium underline text-stone-700 hover:text-stone-900" %></p>
    </div>
    <% if Current.owner == @computer.owner || admin? %>
      <div class="flex gap-2">
        <%= link_to "Edit", edit_computer_path(@computer), class: button_classes(style: :primary) %>
        <%= button_to "Delete", computer_path(@computer), method: :delete, data: { turbo_confirm: "Are you sure?" }, class: button_classes(style: :secondary) %>
      </div>
    <% end %>
  </div>

  <%# ── Computer fields ── %>
  <dl class="space-y-4 text-sm mb-6">

    <%# Line 1 (3-col): Model | Order Number | Serial Number %>
    <div class="grid grid-cols-3 gap-4">
      <div>
        <dt class="text-xs font-medium text-stone-500 uppercase tracking-wider mb-1">Model</dt>
        <dd class="flex items-center w-full h-10 p-3 rounded border border-stone-300 bg-white text-sm"><%= @computer.computer_model.name %></dd>
      </div>
      <div>
        <dt class="text-xs font-medium text-stone-500 uppercase tracking-wider mb-1">Order Number</dt>
        <dd class="flex items-center w-full h-10 p-3 rounded border border-stone-300 bg-white text-sm"><%= @computer.order_number.presence || "—" %></dd>
      </div>
      <div>
        <dt class="text-xs font-medium text-stone-500 uppercase tracking-wider mb-1">Serial Number</dt>
        <dd class="flex items-center w-full h-10 p-3 rounded border border-stone-300 bg-white text-sm"><%= @computer.serial_number %></dd>
      </div>
    </div>

    <%# Line 2: Condition | Run Status | Trade Status (3-col when logged in, 2-col otherwise) %>
    <div class="grid <%= logged_in? ? "grid-cols-3" : "grid-cols-2" %> gap-4">
      <div>
        <dt class="text-xs font-medium text-stone-500 uppercase tracking-wider mb-1">Condition</dt>
        <dd class="flex items-center w-full h-10 p-3 rounded border border-stone-300 bg-white text-sm"><%= @computer.computer_condition&.name || "—" %></dd>
      </div>
      <div>
        <dt class="text-xs font-medium text-stone-500 uppercase tracking-wider mb-1">Run Status</dt>
        <dd class="flex items-center w-full h-10 p-3 rounded border border-stone-300 bg-white text-sm"><%= @computer.run_status&.name || "—" %></dd>
      </div>
      <% if logged_in? %>
        <div>
          <dt class="text-xs font-medium text-stone-500 uppercase tracking-wider mb-1">Trade Status</dt>
          <dd class="flex items-center w-full h-10 p-3 rounded border border-stone-300 bg-white text-sm">
            <% if @computer.barter_status_offered? %>
              <span class="text-green-700">Offered</span>
            <% elsif @computer.barter_status_wanted? %>
              <span class="text-amber-600">Wanted</span>
            <% else %>
              <span class="text-stone-400">—</span>
            <% end %>
          </dd>
        </div>
      <% end %>
    </div>

    <%# Line 3 (full): History %>
    <div>
      <dt class="text-xs font-medium text-stone-500 uppercase tracking-wider mb-1">History</dt>
      <dd class="block w-full p-3 rounded border border-stone-300 bg-white text-sm whitespace-pre-wrap" style="min-height: 4.5rem;"><%= @computer.history.presence || "—" %></dd>
    </div>

  </dl>

  <%# ── Components section ── %>
  <div>
    <div class="flex justify-between items-center mb-3">
      <h2 class="text-lg font-semibold">Components (<%= @components.count %>)</h2>
      <% if Current.owner == @computer.owner || admin? %>
        <%= link_to "Add Component", new_component_path(computer_id: @computer.id), class: button_classes(style: :secondary) %>
      <% end %>
    </div>

    <% if @components.any? %>
      <div class="bg-white border border-stone-200 rounded">
        <table class="min-w-full divide-y divide-stone-200">
          <thead class="bg-stone-50">
            <tr>
              <th class="px-4 py-2 text-left text-xs font-medium text-stone-500 uppercase tracking-wider">Type</th>
              <th class="px-4 py-2 text-left text-xs font-medium text-stone-500 uppercase tracking-wider">Order No.</th>
              <th class="px-4 py-2 text-left text-xs font-medium text-stone-500 uppercase tracking-wider">Serial No.</th>
              <th class="px-4 py-2 text-left text-xs font-medium text-stone-500 uppercase tracking-wider">Description</th>
              <th class="px-4 py-2"></th>
            </tr>
          </thead>
          <tbody class="bg-white divide-y divide-stone-200 text-sm">
            <% @components.each do |component| %>
              <tr class="hover:bg-stone-50">
                <td class="px-4 py-3 whitespace-nowrap font-medium">
                  <%= link_to component.component_type.name, component_path(component), class: "text-indigo-600 hover:text-indigo-900" %>
                </td>
                <td class="px-4 py-3 whitespace-nowrap text-stone-600"><%= component.order_number.presence || "—" %></td>
                <td class="px-4 py-3 whitespace-nowrap text-stone-600"><%= component.serial_number.presence || "—" %></td>
                <td class="px-4 py-3 text-stone-600"><%= truncate(component.description, length: 80) || "—" %></td>
                <td class="px-4 py-3 whitespace-nowrap text-right">
                  <% if Current.owner == @computer.owner || admin? %>
                    <div class="flex items-center justify-end gap-3">
                      <%= link_to "Edit", edit_component_path(component), class: "text-indigo-600 hover:text-indigo-900" %>
                      <%= button_to "Delete", component_path(component), method: :delete,
                            data: { turbo_confirm: "Delete this #{component.component_type.name}? This cannot be undone." },
                            params: { source: "computer_show" },
                            class: "text-red-600 hover:text-red-900 bg-transparent border-0 p-0 cursor-pointer",
                            form: { style: "display:inline" } %>
                    </div>
                  <% end %>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    <% else %>
      <p class="text-sm text-stone-500">No components attached to this <%= @computer.device_type %>.</p>
    <% end %>
  </div>

  <%# ── Connections section (read-only) ── %>
  <%# Shows all connections this device belongs to. %>
  <%# Columns: CONNECTION ID | TYPE | CONNECTION LABEL | PORT ID | CONNECTS | PORT LABEL %>
  <%# One row per port; first row of each group shows the group-level columns. %>
  <%# @connection_groups eager-loads connection_members with computer+model (controller v1.18). %>
  <%# Members sorted in memory by owner_member_id — no extra DB queries per group. %>
  <div class="mt-6">
    <h2 class="text-lg font-semibold mb-3">Connections (<%= @connection_groups.count %>)</h2>

    <% if @connection_groups.any? %>
      <div class="bg-white border border-stone-200 rounded">
        <table class="min-w-full divide-y divide-stone-200">
          <thead class="bg-stone-50">
            <tr>
              <th class="px-4 py-2 text-left text-xs font-medium text-stone-500 uppercase tracking-wider">Connection ID</th>
              <th class="px-4 py-2 text-left text-xs font-medium text-stone-500 uppercase tracking-wider">Type</th>
              <th class="px-4 py-2 text-left text-xs font-medium text-stone-500 uppercase tracking-wider">Connection Label</th>
              <th class="px-4 py-2 text-left text-xs font-medium text-stone-500 uppercase tracking-wider">Port ID</th>
              <th class="px-4 py-2 text-left text-xs font-medium text-stone-500 uppercase tracking-wider">Connects</th>
              <th class="px-4 py-2 text-left text-xs font-medium text-stone-500 uppercase tracking-wider">Port Label</th>
            </tr>
          </thead>
          <tbody class="bg-white text-sm">

            <% @connection_groups.each_with_index do |group, group_idx| %>
              <% members = group.connection_members.sort_by(&:owner_member_id) %>

              <% members.each_with_index do |member, member_idx| %>
                <tr class="hover:bg-stone-50 <%= 'border-t-2 border-stone-300' if group_idx > 0 && member_idx == 0 %> <%= 'border-t border-stone-100' if member_idx > 0 %>">

                  <%# Group columns — first row of each group only. %>
                  <% if member_idx == 0 %>
                    <td class="px-4 py-3 whitespace-nowrap text-stone-600 align-top font-medium">
                      <%= group.owner_group_id %>
                    </td>
                    <td class="px-4 py-3 whitespace-nowrap text-stone-600 align-top">
                      <%= group.connection_type&.name || "—" %>
                    </td>
                    <td class="px-4 py-3 whitespace-nowrap text-stone-600 align-top">
                      <%= group.label.presence || "—" %>
                    </td>
                  <% else %>
                    <td></td><td></td><td></td>
                  <% end %>

                  <%# Port columns — every row. %>
                  <td class="px-4 py-3 whitespace-nowrap text-stone-600">
                    <%= member.owner_member_id %>
                  </td>
                  <td class="px-4 py-3 text-stone-600">
                    <%= link_to "#{member.computer.computer_model.name} – #{member.computer.serial_number}",
                                computer_path(member.computer),
                                class: "text-indigo-600 hover:text-indigo-900" %>
                  </td>
                  <td class="px-4 py-3 text-stone-600">
                    <%= member.label.presence || "" %>
                  </td>

                </tr>
              <% end %>
            <% end %>

          </tbody>
        </table>
      </div>
    <% else %>
      <p class="text-sm text-stone-500">No connections recorded for this <%= @computer.device_type %>.</p>
    <% end %>
  </div>

  <%# ── Back button ── %>
  <div class="mt-6">
    <a href="#"
       data-controller="back"
       data-back-fallback-url-value="<%= owner_path(@computer.owner) %>"
       data-action="click->back#go"
       class="text-sm text-stone-700 hover:text-stone-900">← Back</a>
  </div>

</div>
