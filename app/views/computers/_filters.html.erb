<%# decor/app/views/computers/_filters.html.erb - version 1.5 %>
<%# v1.5 (Session 25): Fixed Type filter visibility condition. %>
<%#   Was: unless @device_context == "appliance" %>
<%#   Now: if @device_context == "computer" %>
<%#   The old condition left the Type filter visible on the Peripherals page, %>
<%#   where device_type is locked to "peripheral" by the controller — the %>
<%#   selector would have no effect and would mislead the user. The correct %>
<%#   rule is: show the Type filter ONLY on the Computers page, where the %>
<%#   user can meaningfully filter between Computer and Appliance types. %>
<%# v1.4 (Session 22): Added "Trade" barter_status filter. %>
<%# v1.3 (Session 17): Form action and Reset link use @index_path. Type selector %>
<%#   hidden on Appliances page. %>
<%# v1.2: Added "Type" filter selector. %>
<%# v1.1: condition_id → computer_condition_id rename. %>

<%= form_with url: @index_path, method: :get, local: true, class: "col-span-1 self-start flex flex-col gap-4 mb-4 p-4 bg-stone-100" do |form| %>
  <div class="-mb-2 font-medium">Filters</div>

  <div>
    <%= form.label :query, "Search", class: "text-sm text-stone-600 font-medium" %>
    <%= form.search_field :query, value: params[:query], placeholder: "Search...", class: field_classes %>
    <p class="text-xs text-stone-500 mt-1">Use % for any characters, _ for single character. Case-insensitive.</p>
  </div>

  <div class="flex flex-col">
    <%= form.label :sort, "Sort", class: "text-sm text-stone-600 font-medium" %>
    <%= form.select :sort, computer_sort_options, { selected: computer_sort_selected }, { class: field_classes } %>
  </div>

  <%# Type filter — only meaningful on the Computers page, where the user can %>
  <%# filter between Computer and Appliance types. On the Appliances and %>
  <%# Peripherals pages device_type is locked by the controller; showing the %>
  <%# selector would have no effect and would mislead the user. %>
  <% if @device_context == "computer" %>
    <div class="flex flex-col">
      <%= form.label :device_type, "Type", class: "text-sm text-stone-600 font-medium" %>
      <%= form.select :device_type, computer_filter_device_type_options, { selected: computer_filter_device_type_selected, include_blank: "Any" }, { class: field_classes } %>
    </div>
  <% end %>

  <div class="flex flex-col">
    <%= form.label :model, "Model", class: "text-sm text-stone-600 font-medium" %>
    <%= form.select :model, computer_filter_models_options, { selected: computer_filter_models_selected, include_blank: "Any" }, { class: field_classes } %>
  </div>

  <div class="flex flex-col">
    <%= form.label :computer_condition_id, "Condition", class: "text-sm text-stone-600 font-medium" %>
    <%= form.select :computer_condition_id, computer_filter_conditions_options, { selected: computer_filter_conditions_selected, include_blank: "Any" }, { class: field_classes } %>
  </div>

  <div class="flex flex-col">
    <%= form.label :run_status_id, "Run Status", class: "text-sm text-stone-600 font-medium" %>
    <%= form.select :run_status_id, computer_filter_run_statuses_options, { selected: computer_filter_run_statuses_selected, include_blank: "Any" }, { class: field_classes } %>
  </div>

  <%# Trade (barter_status) filter — visible to logged-in members only. %>
  <%# Non-logged-in visitors see no barter data anywhere; this block must be %>
  <%# completely absent (not just greyed out) for unauthenticated requests. %>
  <% if logged_in? %>
    <div class="flex flex-col">
      <%= form.label :barter_status, "Trade", class: "text-sm text-stone-600 font-medium" %>
      <%= form.select :barter_status, computer_filter_barter_status_options, { selected: computer_filter_barter_status_selected }, { class: field_classes } %>
    </div>
  <% end %>

  <div class="flex justify-end gap-2">
    <%= link_to "Reset", @index_path, class: button_classes(style: :secondary) %>
    <%= form.submit "Apply", class: button_classes(style: :secondary) %>
  </div>
<% end %>
