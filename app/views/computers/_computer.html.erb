<%# decor/app/views/computers/_computer.html.erb - version 1.10 %>
<%# v1.10 (Session 22): Removed the Type column cell entirely. The Type column %>
<%#   header was removed from index.html.erb at the same time — the Computers page %>
<%#   always shows computers (type is implicit) and the Appliances page always shows %>
<%#   appliances, so the column was redundant on both routes. %>
<%# v1.9 (Session 21): Added "Barter" column (barter_status), visible to logged-in %>
<%#   members only. Cell and its matching header (index.html.erb) are both wrapped %>
<%#   in - if logged_in? - so the column is completely absent for visitors. %>
<%#   Offered → green text; Wanted → amber text; no_barter → em-dash. %>
<%#   Column position: after Run Status, before Actions. %>
<%# v1.8 (Session 17): Type column cell hidden when @device_context == "appliance". %>
<%# v1.7: Added "Type" column after Model. %>
<%# v1.6: computer.condition → computer.computer_condition. %>

<tr id="<%= dom_id computer %>" class="hover:bg-stone-50">
  <!-- Owner -->
  <td class="px-4 py-3 whitespace-nowrap text-stone-600">
    <%= link_to computer.owner.user_name, computer.owner, class: "text-indigo-600 hover:text-indigo-900" %>
  </td>

  <!-- Model -->
  <td class="px-4 py-3 whitespace-nowrap font-medium text-stone-900">
    <%= link_to computer.computer_model.name, computer, class: "text-indigo-600 hover:text-indigo-900" %>
  </td>

  <!-- Order Number -->
  <td class="px-4 py-3 whitespace-nowrap text-stone-600">
    <%= computer.order_number.presence || "—" %>
  </td>

  <!-- Serial Number -->
  <td class="px-4 py-3 whitespace-nowrap text-stone-600">
    <%= computer.serial_number.presence || "—" %>
  </td>

  <!-- Condition -->
  <td class="px-4 py-3 whitespace-nowrap text-stone-600">
    <%= computer.computer_condition&.name || "—" %>
  </td>

  <!-- Run Status -->
  <td class="px-4 py-3 whitespace-nowrap text-stone-600">
    <%= computer.run_status&.name || "—" %>
  </td>

  <%# Barter (barter_status) — members only; column absent entirely for visitors. %>
  <% if logged_in? %>
    <td class="px-4 py-3 whitespace-nowrap">
      <% if computer.barter_status_offered? %>
        <span class="text-green-700">Offered</span>
      <% elsif computer.barter_status_wanted? %>
        <span class="text-amber-600">Wanted</span>
      <% else %>
        <span class="text-stone-400">—</span>
      <% end %>
    </td>
  <% end %>

  <!-- Actions -->
  <td class="px-4 py-3 whitespace-nowrap text-right">
    <% if Current.owner == computer.owner %>
      <%= link_to "Edit", edit_computer_path(computer), class: "text-indigo-600 hover:text-indigo-900" %>
    <% end %>
  </td>
</tr>
