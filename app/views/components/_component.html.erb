<%# decor/app/views/components/_component.html.erb - version 1.6 %>
<%# v1.6 (Session 21): Added "Trade" column (barter_status), visible to logged-in %>
<%#   members only. Cell and its matching header (index.html.erb) are both wrapped %>
<%#   in - if logged_in? - so the column is completely absent for visitors. %>
<%#   Offered → green text; Wanted → amber text; no_barter → em-dash. %>
<%#   Column position: after Owner, before Actions. %>
<%# v1.5 (Session 19): Computer and computer-serial cells merged; column reorder; %>
<%#   Order No. added; Serial No. now shows component's own field. %>

<tr id="<%= dom_id component %>" class="hover:bg-stone-50">
  <%# Computer-Serial No. — "Model – serial" link when attached; "Spare" when unattached %>
  <td class="px-4 py-3 whitespace-nowrap text-stone-600">
    <% if component.computer %>
      <%= link_to "#{component.computer.computer_model.name} \u2013 #{component.computer.serial_number}",
            component.computer,
            class: "text-indigo-600 hover:text-indigo-900" %>
    <% else %>
      <span class="text-stone-400">Spare</span>
    <% end %>
  </td>

  <%# Type — clickable, navigates to component show page %>
  <td class="px-4 py-3 whitespace-nowrap font-medium text-stone-900">
    <%= link_to component.component_type.name, component, class: "text-indigo-600 hover:text-indigo-900" %>
  </td>

  <%# Description — truncated with max-width to prevent layout breaking %>
  <td class="px-4 py-3 text-stone-600" style="max-width: 300px;">
    <div class="truncate">
      <%= component.description.presence || "—" %>
    </div>
  </td>

  <%# Order No. — component's own order number %>
  <td class="px-4 py-3 whitespace-nowrap text-stone-600">
    <%= component.order_number.presence || "—" %>
  </td>

  <%# Serial No. — component's own serial number %>
  <td class="px-4 py-3 whitespace-nowrap text-stone-600">
    <%= component.serial_number.presence || "—" %>
  </td>

  <%# Owner — link to owner show page %>
  <td class="px-4 py-3 whitespace-nowrap text-stone-600">
    <%= link_to component.owner.user_name, component.owner, class: "text-indigo-600 hover:text-indigo-900" %>
  </td>

  <%# Trade (barter_status) — members only; column absent entirely for visitors. %>
  <% if logged_in? %>
    <td class="px-4 py-3 whitespace-nowrap">
      <% if component.barter_status_offered? %>
        <span class="text-green-700">Offered</span>
      <% elsif component.barter_status_wanted? %>
        <span class="text-amber-600">Wanted</span>
      <% else %>
        <span class="text-stone-400">—</span>
      <% end %>
    </td>
  <% end %>

  <%# Actions — Edit shown to the record's owner only %>
  <td class="px-4 py-3 whitespace-nowrap text-right">
    <% if Current.owner == component.owner %>
      <%= link_to "Edit", edit_component_path(component), class: "text-indigo-600 hover:text-indigo-900" %>
    <% end %>
  </td>
</tr>
