<%# decor/app/views/components/index.html.erb - version 1.6 %>
<%# v1.6 (Session 52): Renamed column header "Computer-Serial No." → %>
<%#   "Device – Serial No." to reflect that components can be installed on %>
<%#   computers or peripherals. No structural change; the cell in %>
<%#   _component.html.erb already renders correctly for both device types. %>
<%#   product terminology. No structural changes. %>
<%# v1.4 (Session 22): Added "Trade" <th> header after Owner, before the empty %>
<%#   Actions column. Wrapped in - if logged_in? — the corresponding %>
<%#   <td> cell in _component.html.erb v1.6 uses the same guard. %>
<%# v1.3 (Session 19): Column changes: %>
<%#   - "Computer" and "Serial Number" merged into "Computer-Serial No." %>
<%#   - Column order: Computer-Serial No. | Type | Description | Order No. | Serial No. | Owner %>
<%#   - "Order No." added between Description and Serial No. %>

<div class="px-4">
  <h1 class="text-2xl font-semibold mb-4 sticky top-0 bg-white z-10 py-2">Components</h1>

  <div class="grid grid-cols-1 md:grid-cols-4 gap-4">
    <div class="sticky top-16 self-start">
      <%= render "filters" %>
    </div>

    <div class="col-span-3 self-start">
      <% if @page.records.any? %>
        <div class="bg-white border border-stone-200 rounded overflow-auto" style="max-height: calc(100vh - 8rem);">
          <table class="min-w-full divide-y divide-stone-200">
            <thead class="bg-stone-50 sticky top-0 z-10">
              <tr>
                <%# Combined device model name and serial number — covers both computers and peripherals %>
                <th class="px-4 py-2 text-left text-xs font-medium text-stone-500 uppercase tracking-wider">Device – Serial No.</th>
                <th class="px-4 py-2 text-left text-xs font-medium text-stone-500 uppercase tracking-wider">Type</th>
                <th class="px-4 py-2 text-left text-xs font-medium text-stone-500 uppercase tracking-wider">Description</th>
                <%# Component's own order number %>
                <th class="px-4 py-2 text-left text-xs font-medium text-stone-500 uppercase tracking-wider">Order No.</th>
                <%# Component's own serial number %>
                <th class="px-4 py-2 text-left text-xs font-medium text-stone-500 uppercase tracking-wider">Serial No.</th>
                <th class="px-4 py-2 text-left text-xs font-medium text-stone-500 uppercase tracking-wider">Owner</th>
                <%# Barter header — visible to logged-in members only. %>
                <%# The matching <td> in _component.html.erb v1.6 uses the same guard. %>
                <% if logged_in? %>
                  <th class="px-4 py-2 text-left text-xs font-medium text-stone-500 uppercase tracking-wider">Barter</th>
                <% end %>
                <th class="px-4 py-2"></th>
              </tr>
            </thead>
            <tbody id="components" class="bg-white divide-y divide-stone-200 text-sm">
              <% @page.records.each do |component| %>
                <%= render "component", component: component %>
              <% end %>
            </tbody>
          </table>
        </div>
      <% else %>
        <%= empty_state("No components found matching your search") %>
      <% end %>
    </div>

    <%= render "shared/load_more", id: :load_more_components, page: @page, path: components_path %>
  </div>

</div>
