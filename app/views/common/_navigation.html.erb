<%# decor/app/views/common/_navigation.html.erb - version 1.4 %>
<%# v1.4 (Session 20): Replaced standalone "Read Me" link with "Info" dropdown menu. %>
<%#   Dropdown entries: Read Me (/readme), News (/news), %>
<%#                     Barter Trade (/barter_trade), Privacy (/privacy). %>
<%#   Uses the existing dropdown_controller.js (Stimulus) — same pattern as the %>
<%#   Admin dropdown in admin.html.erb. No new JS needed. %>
<%# v1.3 (Session 18): Added "Read Me" as the leftmost navigation link. %>
<%# v1.2 (Session 17): Added Appliances navigation link between Computers and Components. %>
<%# v1.1: Admin link now only shows to users where admin? returns true. %>

<nav class="grid grid-cols-3 items-center gap-2 px-6 py-4">
  <div class="flex items-center justify-start gap-6">

    <%# Info dropdown — replaces the former standalone "Read Me" link. %>
    <%# dropdown_controller.js toggles the "hidden" class on the menu div. %>
    <div class="relative" data-controller="dropdown">
      <button data-action="click->dropdown#toggle click@window->dropdown#hide"
              class="text-sm font-medium text-stone-700 hover:text-stone-900 flex items-center gap-1">
        Info
        <%# Chevron-down indicator — matches the admin dropdown style %>
        <svg class="w-3 h-3 text-stone-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
        </svg>
      </button>

      <div data-dropdown-target="menu"
           class="hidden absolute left-0 mt-1 w-36 bg-white border border-stone-200 rounded shadow-lg z-50">
        <%= link_to "Read Me",     readme_path,       class: "block px-4 py-2 text-sm text-stone-700 hover:bg-stone-50" %>
        <%= link_to "News",        news_path,         class: "block px-4 py-2 text-sm text-stone-700 hover:bg-stone-50" %>
        <%= link_to "Barter Trade", barter_trade_path, class: "block px-4 py-2 text-sm text-stone-700 hover:bg-stone-50" %>
        <%= link_to "Privacy",     privacy_path,      class: "block px-4 py-2 text-sm text-stone-700 hover:bg-stone-50" %>
      </div>
    </div>

    <%= navigation_link_to "Owners",     owners_path %>
    <%= navigation_link_to "Computers",  computers_path %>
    <%= navigation_link_to "Appliances", appliances_path %>
    <%= navigation_link_to "Components", components_path %>
  </div>

  <div class="flex-1 flex justify-center">
    <%= link_to root_path do %>
      <%= image_tag "logo.png", class: "h-8"%>
    <% end %>
  </div>

  <div class="flex items-center justify-end gap-6">
    <% if logged_in? %>
      <%# Only show Admin link to users with admin privileges %>
      <% if admin? %>
        <%= navigation_link_to "Admin", admin_owners_path %>
      <% end %>
      <%= navigation_link_to Current.owner.user_name, owner_path(Current.owner), active: false %>
    <% else %>
      <%= navigation_link_to "Log In", new_session_path %>
    <% end %>
  </div>
</nav>
