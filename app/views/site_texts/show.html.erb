<%# decor/app/views/site_texts/show.html.erb - version 1.0 %>
<%# v1.0 (Session 18): Public page for named text content (README etc.). %>
<%#   Renders stored markdown as formatted HTML via the render_markdown helper. %>
<%#   Displays "== Empty ==" when no content has been uploaded yet. %>
<%#   Prose styles are applied via a scoped <style> block since the project %>
<%#   does not use the Tailwind Typography plugin. %>

<style>
  /* Prose styles for redcarpet-rendered markdown output.
     Colors use the stone/indigo palette consistent with the rest of the app. */
  .markdown-content h1 { font-size: 1.5rem;  font-weight: 600; margin: 1.5rem 0 0.75rem; }
  .markdown-content h2 { font-size: 1.25rem; font-weight: 600; margin: 1.5rem 0 0.75rem; }
  .markdown-content h3 { font-size: 1.1rem;  font-weight: 600; margin: 1.25rem 0 0.5rem; }
  .markdown-content h4,
  .markdown-content h5,
  .markdown-content h6 { font-size: 1rem;    font-weight: 600; margin: 1rem 0 0.4rem; }
  .markdown-content p  { margin-bottom: 0.875rem; line-height: 1.6; }
  .markdown-content ul { list-style-type: disc;    margin: 0.75rem 0 0.75rem 1.75rem; }
  .markdown-content ol { list-style-type: decimal; margin: 0.75rem 0 0.75rem 1.75rem; }
  .markdown-content li { margin-bottom: 0.3rem; line-height: 1.6; }
  .markdown-content a  { color: #4f46e5; text-decoration: underline; }
  .markdown-content a:hover { color: #3730a3; }
  .markdown-content strong { font-weight: 600; }
  .markdown-content em     { font-style: italic; }
  .markdown-content hr     { margin: 1.5rem 0; border-color: #e7e5e4; }
  .markdown-content blockquote {
    border-left: 3px solid #d6d3d1;
    padding-left: 1rem;
    color: #78716c;
    margin: 0.875rem 0;
    font-style: italic;
  }
  .markdown-content code {
    background: #f5f5f4;
    padding: 0.15em 0.35em;
    border-radius: 0.25rem;
    font-size: 0.875em;
    font-family: ui-monospace, monospace;
  }
  .markdown-content pre {
    background: #f5f5f4;
    padding: 1rem;
    border-radius: 0.375rem;
    overflow-x: auto;
    margin-bottom: 0.875rem;
  }
  .markdown-content pre code {
    background: none;
    padding: 0;
    font-size: 0.875rem;
  }
  .markdown-content table {
    width: 100%;
    border-collapse: collapse;
    margin-bottom: 0.875rem;
    font-size: 0.875rem;
  }
  .markdown-content th,
  .markdown-content td {
    border: 1px solid #e7e5e4;
    padding: 0.5rem 0.75rem;
    text-align: left;
  }
  .markdown-content th {
    background: #f5f5f4;
    font-weight: 600;
    color: #57534e;
    text-transform: uppercase;
    font-size: 0.75rem;
    letter-spacing: 0.05em;
  }
</style>

<div class="max-w-4xl mx-auto px-4 py-6">
  <h1 class="text-2xl font-semibold mb-6"><%= @title %></h1>

  <% if @site_text.present? %>
    <%# Render the stored markdown as formatted HTML. %>
    <%# render_markdown is defined in ApplicationHelper (v1.1). %>
    <div class="markdown-content text-sm text-stone-800">
      <%= render_markdown(@site_text.content) %>
    </div>
  <% else %>
    <%# No content uploaded yet — show placeholder as requested. %>
    <p class="text-stone-500 text-sm">== Empty ==</p>
  <% end %>
</div>
