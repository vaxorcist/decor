<div class="max-w-2xl mx-auto px-4 py-6">

  <p class="text-sm text-stone-500 mb-1">
    <%= link_to "My Connections", owner_connection_groups_path(@owner),
                class: "text-indigo-600 hover:text-indigo-900" %>
