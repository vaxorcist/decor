<%# decor/app/views/data_transfers/show.html.erb %>
<%# version 1.9 %>
<%# v1.9 (Session 49 — Session G): Complete rewrite for OwnerImportService v1.8 and %>
<%#   OwnerExportService v1.8 (per-section CSV format). %>
<%#   Import notes: removed "all rows succeed or none are saved" (atomicity) bullet; %>
<%#     added per-row independent save note; updated error-row bullet. %>
<%#   Added flash[:row_warnings] display block (amber) — rows saved with a caveat. %>
<%#   Added flash[:row_errors] display block (red) — rows that were skipped. %>
<%#   CSV Format section: complete rewrite for v1.7+ per-section format. %>
<%#     Replaced the old single 12-column table with separate per-section column tables %>
<%#     (computers/peripherals, components, connections, software). %>
<%#     Updated example CSV to show sentinel + section-header + data-row layout. %>
<%#     Retained "appliance" backward-compatibility note (importer still accepts it). %>
<%# v1.8 (Session 42): Appliances → Peripherals merger cleanup. %>
<%# Session 28: Removed inline flash rendering (layout's _flashes.html.erb handles notice + alert). %>
<%# %>
<%# Auth: before_action :require_login in DataTransfersController (v1.1+). %>
<%# flash[:notice] and flash[:alert] are rendered by the layout — not duplicated here. %>
<%# flash[:row_errors] and flash[:row_warnings] are custom and rendered inline below. %>

<div class="max-w-3xl mx-auto">
  <h1 class="text-2xl font-semibold mb-6">Export / Import Your Data</h1>

  <%# ── Row warnings — rows saved with a caveat (e.g. software imported as %>
  <%# unattached because the specified computer was not found). %>
  <%# Rendered here rather than by the layout because these are custom flash keys. %>
  <% if flash[:row_warnings].present? %>
    <div class="mb-4 p-4 rounded border border-amber-300 bg-amber-50 text-amber-800 text-sm">
      <p class="font-medium mb-2">Import warnings — these rows were saved with adjustments:</p>
      <ul class="list-disc list-inside space-y-1">
        <% flash[:row_warnings].each do |warning| %>
          <li><%= warning %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <%# ── Row errors — rows that were skipped (not saved). %>
  <% if flash[:row_errors].present? %>
    <div class="mb-6 p-4 rounded border border-red-300 bg-red-50 text-red-800 text-sm">
      <p class="font-medium mb-2">The following rows could not be imported and were skipped:</p>
      <ul class="list-disc list-inside space-y-1">
        <% flash[:row_errors].each do |error| %>
          <li><%= error %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <%# ════════════════════════════════════════════════════════════════════════ %>
  <%# EXPORT SECTION                                                           %>
  <%# ════════════════════════════════════════════════════════════════════════ %>
  <div class="bg-white border border-stone-200 rounded p-6 mb-6">
    <h2 class="text-lg font-semibold mb-3">Export</h2>
    <p class="text-sm text-stone-600 mb-4">
      Download all of your computers, peripherals, components, connections, and
      software items as a CSV file. The file can be re-imported here or used as a backup.
    </p>
    <%# inline-flex items-center w-fit: constrains width to text and vertically centres %>
    <%# the label the same way flex does on a submit element. %>
    <%= link_to "Download CSV",
          export_data_transfer_path,
          class: "#{button_classes(style: :primary)} inline-flex items-center w-fit" %>
  </div>

  <%# ════════════════════════════════════════════════════════════════════════ %>
  <%# IMPORT SECTION                                                           %>
  <%# ════════════════════════════════════════════════════════════════════════ %>
  <div class="bg-white border border-stone-200 rounded p-6 mb-6">
    <h2 class="text-lg font-semibold mb-3">Import</h2>
    <p class="text-sm text-stone-600 mb-1">
      Upload a CSV file in the format described below to add computers,
      peripherals, components, connections, and software items to your account.
    </p>
    <ul class="text-sm text-stone-600 mb-4 list-disc list-inside space-y-1">
      <li>Records that already exist (matched by serial number) are skipped — safe to re-import.</li>
      <li>Each row is imported independently — rows that succeed are saved even if other rows fail.</li>
      <li>If a required lookup fails (model, condition, etc.), that row is skipped and listed below after import.</li>
      <li>A software item whose computer is not found is saved as unattached (a warning, not an error).</li>
      <li>A component whose parent computer is not found is imported as a spare (not an error).</li>
    </ul>

    <%# multipart: true is required for file uploads %>
    <%= form_with url: import_data_transfer_path, method: :post, multipart: true, class: "space-y-4" do |f| %>
      <div>
        <%= f.label :file, "CSV File", class: "block text-sm font-medium text-stone-700 mb-1" %>
        <%= f.file_field :file,
              accept: ".csv",
              required: true,
              class: "block w-full text-sm text-stone-600
                      file:mr-4 file:py-2 file:px-4 file:rounded
                      file:border-0 file:text-sm file:font-medium
                      file:bg-indigo-50 file:text-indigo-700
                      hover:file:bg-indigo-100" %>
        <p class="mt-1 text-xs text-stone-500">Maximum file size: 10 MB.</p>
      </div>
      <div>
        <%= f.submit "Import CSV", class: button_classes(style: :primary) %>
      </div>
    <% end %>
  </div>

  <%# ════════════════════════════════════════════════════════════════════════ %>
  <%# CSV FORMAT REFERENCE                                                     %>
  <%# ════════════════════════════════════════════════════════════════════════ %>
  <div class="bg-white border border-stone-200 rounded p-6 mb-6">
    <h2 class="text-lg font-semibold mb-3">CSV Format</h2>
    <p class="text-sm text-stone-600 mb-4">
      The CSV uses a <strong>per-section format</strong>. Each section starts with a sentinel
      line (<code class="font-mono bg-stone-100 px-1 rounded">! --- section-name ---</code>)
      followed by a column-declaration row, then data rows for that section.
      Empty sections are omitted. Blank cells are allowed for optional columns.
    </p>

    <%# ── Computers / Peripherals ── %>
    <h3 class="text-sm font-semibold text-stone-700 mt-4 mb-1">Computers &amp; Peripherals</h3>
    <p class="text-sm text-stone-600 mb-2">
      Section sentinels: <code class="font-mono bg-stone-100 px-1 rounded">! --- computers ---</code>
      and <code class="font-mono bg-stone-100 px-1 rounded">! --- peripherals ---</code>.
      Both sections use the same columns.
    </p>
    <div class="overflow-x-auto mb-3">
      <table class="min-w-full text-xs">
        <thead class="bg-stone-50">
          <tr>
            <th class="px-3 py-2 text-left font-medium text-stone-500 uppercase tracking-wider">Column</th>
            <th class="px-3 py-2 text-left font-medium text-stone-500 uppercase tracking-wider">Notes</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-stone-100 text-stone-700">
          <tr class="bg-white"><td class="px-3 py-2 font-mono">record_type</td><td class="px-3 py-2"><span class="font-medium">Required.</span> <code class="font-mono bg-stone-100 px-1 rounded">computer</code> or <code class="font-mono bg-stone-100 px-1 rounded">peripheral</code>.</td></tr>
          <tr class="bg-stone-50"><td class="px-3 py-2 font-mono">model</td><td class="px-3 py-2"><span class="font-medium">Required.</span> Must match an existing computer or peripheral model.</td></tr>
          <tr class="bg-white"><td class="px-3 py-2 font-mono">order_number</td><td class="px-3 py-2">Optional. Max 20 characters.</td></tr>
          <tr class="bg-stone-50"><td class="px-3 py-2 font-mono">serial_number</td><td class="px-3 py-2"><span class="font-medium">Required.</span> Max 20 characters. Used to detect duplicates.</td></tr>
          <tr class="bg-white"><td class="px-3 py-2 font-mono">condition</td><td class="px-3 py-2">Optional. Must match an existing condition.</td></tr>
          <tr class="bg-stone-50"><td class="px-3 py-2 font-mono">run_status</td><td class="px-3 py-2">Optional. Must match an existing run status.</td></tr>
          <tr class="bg-white"><td class="px-3 py-2 font-mono">history</td><td class="px-3 py-2">Optional. Free text.</td></tr>
          <tr class="bg-stone-50"><td class="px-3 py-2 font-mono">barter_status</td><td class="px-3 py-2">Optional. <code class="font-mono bg-stone-100 px-1 rounded">no_barter</code>, <code class="font-mono bg-stone-100 px-1 rounded">offered</code>, or <code class="font-mono bg-stone-100 px-1 rounded">wanted</code>. Defaults to <code class="font-mono bg-stone-100 px-1 rounded">no_barter</code>.</td></tr>
        </tbody>
      </table>
    </div>

    <%# ── Components ── %>
    <h3 class="text-sm font-semibold text-stone-700 mt-4 mb-1">Components</h3>
    <p class="text-sm text-stone-600 mb-2">
      Section sentinel: <code class="font-mono bg-stone-100 px-1 rounded">! --- components ---</code>.
    </p>
    <div class="overflow-x-auto mb-3">
      <table class="min-w-full text-xs">
        <thead class="bg-stone-50">
          <tr>
            <th class="px-3 py-2 text-left font-medium text-stone-500 uppercase tracking-wider">Column</th>
            <th class="px-3 py-2 text-left font-medium text-stone-500 uppercase tracking-wider">Notes</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-stone-100 text-stone-700">
          <tr class="bg-white"><td class="px-3 py-2 font-mono">record_type</td><td class="px-3 py-2"><span class="font-medium">Required.</span> Value: <code class="font-mono bg-stone-100 px-1 rounded">component</code>.</td></tr>
          <tr class="bg-stone-50"><td class="px-3 py-2 font-mono">installed_on_serial</td><td class="px-3 py-2">Optional. Serial of the parent computer/peripheral. Leave blank for spares.</td></tr>
          <tr class="bg-white"><td class="px-3 py-2 font-mono">type</td><td class="px-3 py-2"><span class="font-medium">Required.</span> Must match an existing component type.</td></tr>
          <tr class="bg-stone-50"><td class="px-3 py-2 font-mono">category</td><td class="px-3 py-2">Optional. <code class="font-mono bg-stone-100 px-1 rounded">integral</code> or <code class="font-mono bg-stone-100 px-1 rounded">peripheral</code>. Defaults to <code class="font-mono bg-stone-100 px-1 rounded">integral</code>.</td></tr>
          <tr class="bg-white"><td class="px-3 py-2 font-mono">order_number</td><td class="px-3 py-2">Optional. Max 20 characters.</td></tr>
          <tr class="bg-stone-50"><td class="px-3 py-2 font-mono">serial_number</td><td class="px-3 py-2">Optional. Max 20 characters. Used to detect duplicates.</td></tr>
          <tr class="bg-white"><td class="px-3 py-2 font-mono">condition</td><td class="px-3 py-2">Optional. Must match an existing component condition.</td></tr>
          <tr class="bg-stone-50"><td class="px-3 py-2 font-mono">description</td><td class="px-3 py-2">Optional. Free text.</td></tr>
          <tr class="bg-white"><td class="px-3 py-2 font-mono">barter_status</td><td class="px-3 py-2">Optional. Defaults to <code class="font-mono bg-stone-100 px-1 rounded">no_barter</code>.</td></tr>
        </tbody>
      </table>
    </div>

    <%# ── Connections ── %>
    <h3 class="text-sm font-semibold text-stone-700 mt-4 mb-1">Connections</h3>
    <p class="text-sm text-stone-600 mb-2">
      Section sentinel: <code class="font-mono bg-stone-100 px-1 rounded">! --- connections ---</code>.
      Each group row is followed immediately by its member rows.
    </p>
    <div class="overflow-x-auto mb-3">
      <table class="min-w-full text-xs">
        <thead class="bg-stone-50">
          <tr>
            <th class="px-3 py-2 text-left font-medium text-stone-500 uppercase tracking-wider">Column</th>
            <th class="px-3 py-2 text-left font-medium text-stone-500 uppercase tracking-wider">Group row</th>
            <th class="px-3 py-2 text-left font-medium text-stone-500 uppercase tracking-wider">Member row</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-stone-100 text-stone-700">
          <tr class="bg-white"><td class="px-3 py-2 font-mono">record_type</td><td class="px-3 py-2"><code class="font-mono bg-stone-100 px-1 rounded">connection_group</code></td><td class="px-3 py-2"><code class="font-mono bg-stone-100 px-1 rounded">connection_member</code></td></tr>
          <tr class="bg-stone-50"><td class="px-3 py-2 font-mono">connection_type_or_model</td><td class="px-3 py-2">Optional. Connection type name.</td><td class="px-3 py-2">Optional. Computer model name (helps disambiguate serials).</td></tr>
          <tr class="bg-white"><td class="px-3 py-2 font-mono">label</td><td class="px-3 py-2">Optional. Group label.</td><td class="px-3 py-2">Leave blank.</td></tr>
          <tr class="bg-stone-50"><td class="px-3 py-2 font-mono">serial_number</td><td class="px-3 py-2">Leave blank.</td><td class="px-3 py-2"><span class="font-medium">Required.</span> Serial of the computer/peripheral.</td></tr>
        </tbody>
      </table>
    </div>

    <%# ── Software ── %>
    <h3 class="text-sm font-semibold text-stone-700 mt-4 mb-1">Software</h3>
    <p class="text-sm text-stone-600 mb-2">
      Section sentinel: <code class="font-mono bg-stone-100 px-1 rounded">! --- software ---</code>.
    </p>
    <div class="overflow-x-auto mb-3">
      <table class="min-w-full text-xs">
        <thead class="bg-stone-50">
          <tr>
            <th class="px-3 py-2 text-left font-medium text-stone-500 uppercase tracking-wider">Column</th>
            <th class="px-3 py-2 text-left font-medium text-stone-500 uppercase tracking-wider">Notes</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-stone-100 text-stone-700">
          <tr class="bg-white"><td class="px-3 py-2 font-mono">record_type</td><td class="px-3 py-2"><span class="font-medium">Required.</span> Value: <code class="font-mono bg-stone-100 px-1 rounded">software_item</code>.</td></tr>
          <tr class="bg-stone-50"><td class="px-3 py-2 font-mono">installed_on_model</td><td class="px-3 py-2">Optional. Model name of the computer it is installed on.</td></tr>
          <tr class="bg-white"><td class="px-3 py-2 font-mono">installed_on_serial</td><td class="px-3 py-2">Optional. Serial of the computer it is installed on. Leave blank for unattached software.</td></tr>
          <tr class="bg-stone-50"><td class="px-3 py-2 font-mono">name</td><td class="px-3 py-2"><span class="font-medium">Required.</span> Must match an existing software name.</td></tr>
          <tr class="bg-white"><td class="px-3 py-2 font-mono">version</td><td class="px-3 py-2">Optional. Max 20 characters.</td></tr>
          <tr class="bg-stone-50"><td class="px-3 py-2 font-mono">condition</td><td class="px-3 py-2">Optional. Must match an existing software condition.</td></tr>
          <tr class="bg-white"><td class="px-3 py-2 font-mono">description</td><td class="px-3 py-2">Optional. Max 100 characters.</td></tr>
          <tr class="bg-stone-50"><td class="px-3 py-2 font-mono">history</td><td class="px-3 py-2">Optional. Max 200 characters.</td></tr>
          <tr class="bg-white"><td class="px-3 py-2 font-mono">barter_status</td><td class="px-3 py-2">Optional. Defaults to <code class="font-mono bg-stone-100 px-1 rounded">no_barter</code>.</td></tr>
        </tbody>
      </table>
    </div>

    <%# ── Example CSV ── %>
    <h3 class="text-sm font-semibold text-stone-700 mt-4 mb-2">Example</h3>
    <pre class="text-xs bg-stone-50 border border-stone-200 rounded p-3 overflow-x-auto text-stone-700"># Owner: alice — exported 2026-04-06
! --- computers ---
record_type,model,order_number,serial_number,condition,run_status,history,barter_status
computer,PDP-11/70,ORD-1985-001,SN12345,Completely original,Working,Lab system,no_barter
! --- peripherals ---
record_type,model,order_number,serial_number,condition,run_status,history,barter_status
peripheral,DEC VT278,,,VT-001,,,no_barter
! --- components ---
record_type,installed_on_serial,type,category,order_number,serial_number,condition,description,barter_status
component,SN12345,Memory Board,integral,MB-001,MB-SN-01,Working,256KB core memory,no_barter
component,,Memory Board,integral,,,,,no_barter
! --- connections ---
record_type,connection_type_or_model,label,serial_number
connection_group,RS-232 Serial,Lab link,
connection_member,PDP-11/70,,SN12345
connection_member,VAX-11/780,,VAX-001
! --- software ---
record_type,installed_on_model,installed_on_serial,name,version,condition,description,history,barter_status
software_item,PDP-11/70,SN12345,TOPS-20,V7.0,Complete,,Production system,no_barter
software_item,,,RT-11,V5.3,Complete,Unattached copy,,no_barter</pre>
    <p class="mt-2 text-xs text-stone-500">
      The spare component row has no <code class="font-mono">installed_on_serial</code> — imported unattached.
      The second software row has no <code class="font-mono">installed_on_serial</code> — imported as unattached software.
    </p>
    <p class="mt-2 text-xs text-stone-500">
      <strong>Backward compatibility:</strong> CSVs exported before v1.7 use a single global header row
      instead of per-section sentinels. The importer accepts both formats.
      The legacy record_type value <code class="font-mono">appliance</code> is also accepted
      and treated as <code class="font-mono">peripheral</code>.
    </p>
  </div>

  <%# Back button %>
  <div class="mt-2">
    <a href="#"
       data-controller="back"
       data-back-fallback-url-value="<%= owner_path(Current.owner) %>"
       data-action="click->back#go"
       class="text-sm text-stone-700 hover:text-stone-900">← Back</a>
  </div>
</div>
